{
  "category_id": "mantas_termicas",
  "name": "Mantas térmicas",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 manta)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 0.82, 'grupo_etario': 0.36, 'medida': 0.3, 'desechabilidad': 0.3, 'material': 0.34}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "emergencia",
        "clinica"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bbajo\\s+paciente\\b",
          "value": "clinica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bclinica\\b",
          "value": "clinica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bwarm\\s*touch\\b",
          "value": "clinica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcalefactora\\b",
          "value": "clinica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcalentamiento\\b",
          "value": "clinica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmulti\\s*posicionamiento\\b",
          "value": "clinica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcsz\\b",
          "value": "clinica"
        },
        {
          "kind": "keyword",
          "pattern": "\\btyco\\b",
          "value": "clinica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bemergencia\\b",
          "value": "emergencia"
        },
        {
          "kind": "keyword",
          "pattern": "\\brescate\\b",
          "value": "emergencia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bisotermica\\b",
          "value": "emergencia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhipotermia\\b",
          "value": "emergencia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhpmk\\b",
          "value": "emergencia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhpkm\\b",
          "value": "emergencia"
        },
        {
          "kind": "keyword",
          "pattern": "alumini",
          "value": "emergencia"
        },
        {
          "kind": "keyword",
          "pattern": "alimini",
          "value": "emergencia"
        }
      ],
      "curation_notes": "Identity: separa la manta isotermica desechable de emergencia/rescate (lamina aluminizada) de la manta clinica calefactora bajo paciente (usada con unidades de calentamiento warm touch/csz/tyco); ambos subtipos coexisten y son productos distintos."
    },
    {
      "name": "grupo_etario",
      "role": "identity",
      "domain": [
        "adulto",
        "pediatrico",
        "neonatal"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bneonatal\\b",
          "value": "neonatal"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpediatric",
          "value": "pediatrico"
        },
        {
          "kind": "keyword",
          "pattern": "\\badulto\\b",
          "value": "adulto"
        }
      ],
      "curation_notes": "Identity: la poblacion (adulto/pediatrico/neonatal) determina tamano y diseno del producto y aparece explicita; orden neonatal>pediatrico>adulto por especificidad."
    },
    {
      "name": "medida",
      "role": "identity",
      "domain": [
        "210x160",
        "120x130",
        "210x130",
        "210x140",
        "40x70",
        "213x91"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\b210\\s*(?:x|por)?\\s*160\\b",
          "value": "210x160"
        },
        {
          "kind": "keyword",
          "pattern": "\\b160\\s*(?:x|por)?\\s*210\\b",
          "value": "210x160"
        },
        {
          "kind": "keyword",
          "pattern": "\\b210\\s*(?:x|por)?\\s*140\\b",
          "value": "210x140"
        },
        {
          "kind": "keyword",
          "pattern": "\\b140\\s*(?:x|por)?\\s*210\\b",
          "value": "210x140"
        },
        {
          "kind": "keyword",
          "pattern": "\\b210\\s*(?:x|por)?\\s*130\\b",
          "value": "210x130"
        },
        {
          "kind": "keyword",
          "pattern": "\\b120\\s*(?:x|por)?\\s*130\\b",
          "value": "120x130"
        },
        {
          "kind": "keyword",
          "pattern": "\\b213\\s*(?:x|por)?\\s*91\\b",
          "value": "213x91"
        },
        {
          "kind": "keyword",
          "pattern": "\\b40\\s*(?:x|por)?\\s*70\\b",
          "value": "40x70"
        }
      ],
      "curation_notes": "Identity para el subtipo de emergencia: las dimensiones distinguen formatos (cuerpo completo adulto ~210x160 vs neonatal 40x70); se canoniza con la dimension mayor primero para unificar orientaciones invertidas (160x210=210x160).",
      "unit": "cm"
    },
    {
      "name": "desechabilidad",
      "role": "identity",
      "domain": [
        "desechable",
        "reutilizable"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\breutilizable\\b",
          "value": "reutilizable"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdesechable\\b",
          "value": "desechable"
        }
      ],
      "curation_notes": "Identity: el uso unico vs reutilizable es una caracteristica de producto que se especifica en las bases y diferencia articulos; ambos valores observados."
    },
    {
      "name": "material",
      "role": "descriptive",
      "domain": [
        "aluminio",
        "poliester",
        "polipropileno"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bpoliester\\b",
          "value": "poliester"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpolipropileno\\b",
          "value": "polipropileno"
        },
        {
          "kind": "keyword",
          "pattern": "alumini",
          "value": "aluminio"
        },
        {
          "kind": "keyword",
          "pattern": "alimini",
          "value": "aluminio"
        }
      ],
      "curation_notes": "Descriptive: el material reflectante (aluminio/poliester aluminizado/polipropileno) se normaliza pero esta muy correlacionado con tipo=emergencia y no se usa para igualdad."
    }
  ]
}