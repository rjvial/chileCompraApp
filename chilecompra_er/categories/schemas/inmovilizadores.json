        {
          "kind": "regex",
          "pattern": "\\b(?:rodilla|clavicula|hombro|tobillo|inmovilizadora)\\s+(s|m|l)\\b",
          "template": "{1}"
        }
      ],
      "curation_notes": "Identity: la talla letrada distingue unidades del mismo tipo; dominio estandar xs-xl, reglas priorizan 'talla X' explicita y luego token de talla adyacente al sustantivo (listados multi-talla quedan sin valor por ambiguos)."
    },
