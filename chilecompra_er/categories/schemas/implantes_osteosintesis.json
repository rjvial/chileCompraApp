{
  "category_id": "implantes_osteosintesis",
  "name": "Implantes de osteosintesis (placas y tornillos)",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 implante)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 0.88, 'material': 0.28, 'diametro': 0.54, 'tipo_tornillo': 0.34, 'bloqueo': 0.18, 'segmento_anatomico': 0.48}, illegal extractions 1."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "placa",
        "tornillo",
        "clavo_endomedular",
        "aguja_kirschner",
        "alambre",
        "arandela",
        "broca",
        "tapon"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bclavo\\b",
          "value": "clavo_endomedular"
        },
        {
          "kind": "keyword",
          "pattern": "\\bplacas?\\b",
          "value": "placa"
        },
        {
          "kind": "keyword",
          "pattern": "\\bagujas?\\s+k(irschner)?\\b",
          "value": "aguja_kirschner"
        },
        {
          "kind": "keyword",
          "pattern": "\\balambre\\b",
          "value": "alambre"
        },
        {
          "kind": "keyword",
          "pattern": "\\barandelas?\\b",
          "value": "arandela"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbrocas?\\b",
          "value": "broca"
        },
        {
          "kind": "keyword",
          "pattern": "\\btapon\\b",
          "value": "tapon"
        },
        {
          "kind": "keyword",
          "pattern": "\\btornillos?\\b",
          "value": "tornillo"
        }
      ],
      "curation_notes": "Identity: distingue el insumo de osteosintesis (placa vs tornillo vs clavo endomedular, etc.); orden de clavo>placa>tornillo porque los kits placa+tornillo se identifican por la placa."
    },
    {
      "name": "material",
      "role": "identity",
      "domain": [
        "titanio",
        "acero"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\btitani",
          "value": "titanio"
        },
        {
          "kind": "keyword",
          "pattern": "\\bacero\\b",
          "value": "acero"
        }
      ],
      "curation_notes": "Identity: titanio vs acero es propiedad fundamental del implante; keyword captura tambien la grafia 'titaneo'."
    },
    {
      "name": "diametro",
      "role": "identity",
      "domain": [
        "1.0mm",
        "1.3mm",
        "1.5mm",
        "2.0mm",
        "2.4mm",
        "2.5mm",
        "2.7mm",
        "3.2mm",
        "3.5mm",
        "3.7mm",
        "4.0mm",
        "4.5mm",
        "6.5mm",
        "7.3mm"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d\\.\\d)\\b",
          "template": "{1}mm"
        }
      ],
      "curation_notes": "Identity: el calibre/diametro nominal (en mm, formato decimal X.Y) discrimina sistemas y compatibilidad; los largos y conteos de agujeros son enteros y no colisionan con el patron decimal.",
      "unit": "mm"
    },
    {
      "name": "tipo_tornillo",
      "role": "identity",
      "domain": [
        "cortical",
        "esponjosa",
        "canulado",
        "bloqueo"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bcanulad",
          "value": "canulado"
        },
        {
          "kind": "keyword",
          "pattern": "\\besponjosa\\b",
          "value": "esponjosa"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcortical",
          "value": "cortical"
        },
        {
          "kind": "keyword",
          "pattern": "\\btornillos?\\s+(de\\s+)?bloqueo\\b",
          "value": "bloqueo"
        }
      ],
      "curation_notes": "Identity: subtipo funcional del tornillo (cortical/esponjosa/canulado/bloqueo) distingue productos; solo aplica a items de tipo tornillo."
    },
    {
      "name": "bloqueo",
      "role": "identity",
      "domain": [
        "bloqueada",
        "no_bloqueada"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bno\\s+bloqueada\\b",
          "value": "no_bloqueada"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbloqueadas?\\b",
          "value": "bloqueada"
        }
      ],
      "curation_notes": "Identity: placa bloqueada (LCP) vs no bloqueada (DCP) define el sistema; orden no_bloqueada antes que bloqueada para no falsar el negativo."
    },
    {
      "name": "segmento_anatomico",
      "role": "descriptive",
      "domain": [
        "clavicula",
        "humero",
        "tibia",
        "femur",
        "cadera",
        "pelvis",
        "calcaneo",
        "mano",
        "pie",
        "metacarpiano",
        "maxilo_facial"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bmaxilo\\b",
          "value": "maxilo_facial"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmetacarpiano\\b",
          "value": "metacarpiano"
        },
        {
          "kind": "keyword",
          "pattern": "\\bclavicula\\b",
          "value": "clavicula"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhumero\\b",
          "value": "humero"
        },
        {
          "kind": "keyword",
          "pattern": "\\btibia\\b",
          "value": "tibia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfemur\\b",
          "value": "femur"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcadera\\b",
          "value": "cadera"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpelvis\\b",
          "value": "pelvis"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcalcaneo\\b",
          "value": "calcaneo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmano\\b",
          "value": "mano"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpie\\b",
          "value": "pie"
        }
      ],
      "curation_notes": "Descriptive: el segmento anatomico se normaliza para busqueda pero no fija identidad (la misma placa/tornillo sirve a varias regiones)."
    }
  ]
}