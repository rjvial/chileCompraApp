{
  "category_id": "electrocardiografos",
  "name": "Electrocardiógrafos",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 item)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 1.0, 'canales': 0.06, 'derivaciones': 0.1, 'ancho': 0.22, 'marca': 0.5}, illegal extractions 1."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "electrocardiografo",
        "papel",
        "cable_paciente",
        "gel",
        "bateria",
        "electrodo",
        "adaptador",
        "pera_goma"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\b(?:papel|resma|rollo)\\b",
          "value": "papel"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgel\\b",
          "value": "gel"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbaterias?\\b",
          "value": "bateria"
        },
        {
          "kind": "keyword",
          "pattern": "\\belectrodos?\\b",
          "value": "electrodo"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:caiman(?:es)?|adaptador(?:es)?)\\b",
          "value": "adaptador"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpera\\b",
          "value": "pera_goma"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:cables?|derivadas?)\\b",
          "value": "cable_paciente"
        },
        {
          "kind": "keyword",
          "pattern": "\\belectrocardiografo\\b",
          "value": "electrocardiografo"
        }
      ],
      "curation_notes": "Identidad principal: discrimina el equipo de sus consumibles/accesorios (papel, cable, gel, bateria, electrodo, adaptador, pera). 'electrocardiografo' es regla final por aparecer en casi todas las descripciones."
    },
    {
      "name": "canales",
      "role": "identity",
      "domain": [
        "3canales",
        "6canales",
        "12canales"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*canales\\b",
          "template": "{1}canales"
        }
      ],
      "curation_notes": "Identity solo para el equipo: el numero de canales (3/6/12) distingue modelos de electrocardiografo; vacio en consumibles.",
      "unit": "canales"
    },
    {
      "name": "derivaciones",
      "role": "identity",
      "domain": [
        "3derivaciones",
        "5derivaciones",
        "10derivaciones",
        "12derivaciones"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*derivaciones\\b",
          "template": "{1}derivaciones"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*derivad[ao]s?\\b",
          "template": "{1}derivaciones"
        }
      ],
      "curation_notes": "Identity para cables/sets de paciente: el numero de derivaciones/derivadas (10, 12) distingue el cable; aplica tambien a equipos con 12 derivaciones.",
      "unit": "derivaciones"
    },
    {
      "name": "ancho",
      "role": "identity",
      "domain": [
        "57mm",
        "60mm",
        "63mm",
        "80mm",
        "110mm",
        "112mm",
        "210mm"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{2,3})\\s*mm\\b",
          "template": "{1}mm"
        }
      ],
      "curation_notes": "Identity para el papel termico: el ancho del rollo/resma en mm distingue compatibilidad; vacio en otros tipos.",
      "unit": "mm"
    },
    {
      "name": "marca",
      "role": "descriptive",
      "domain": [
        "general_electric",
        "nihon_kohden",
        "welch_allyn",
        "philips",
        "mortara",
        "btl",
        "edan",
        "bionet",
        "innomed",
        "fukuda"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bnihon\\b",
          "value": "nihon_kohden"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgeneral electric\\b",
          "value": "general_electric"
        },
        {
          "kind": "keyword",
          "pattern": "\\bwelch allyn\\b",
          "value": "welch_allyn"
        },
        {
          "kind": "keyword",
          "pattern": "\\bphilips\\b",
          "value": "philips"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmortara\\b",
          "value": "mortara"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbtl\\b",
          "value": "btl"
        },
        {
          "kind": "keyword",
          "pattern": "\\bedan\\b",
          "value": "edan"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbionet\\b",
          "value": "bionet"
        },
        {
          "kind": "keyword",
          "pattern": "\\binnomed\\b",
          "value": "innomed"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfukuda\\b",
          "value": "fukuda"
        }
      ],
      "curation_notes": "Descriptive: la marca/modelo indica compatibilidad pero no fija identidad del producto; se normaliza sin participar en la igualdad."
    }
  ]
}