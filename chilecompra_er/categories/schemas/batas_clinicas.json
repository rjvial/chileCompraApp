{
  "category_id": "batas_clinicas",
  "name": "Batas clínicas",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 bata)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 0.62, 'esteril': 0.28, 'desechable': 0.32, 'talla': 0.48, 'material': 0.24, 'manga': 0.24}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "quirurgica",
        "paciente",
        "practicante",
        "procedimiento"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bquirurgic\\w*\\b|\\bcirujano\\b|\\boperacion\\b|\\bneurocirugia\\b",
          "value": "quirurgica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpaciente\\b|\\bpacientes\\b|\\bhospitalizacion\\b|\\bhospitalizado\\w*\\b|\\bcamisola\\b|\\bembarazada\\b|\\blactancia\\b",
          "value": "paciente"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpracticante\\b",
          "value": "practicante"
        },
        {
          "kind": "keyword",
          "pattern": "\\bprocedimiento\\w*\\b",
          "value": "procedimiento"
        }
      ],
      "curation_notes": "Identity: distingue el destino/uso de la bata (quirurgica vs paciente vs practicante vs procedimiento); reglas ordenadas de mas especifica a mas general, quirurgica prevalece cuando coexiste con paciente."
    },
    {
      "name": "esteril",
      "role": "identity",
      "domain": [
        "esteril",
        "no_esteril"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bno\\s+esteril\\w*\\b",
          "value": "no_esteril"
        },
        {
          "kind": "keyword",
          "pattern": "\\besteril\\w*\\b",
          "value": "esteril"
        }
      ],
      "curation_notes": "Identity: la condicion de esterilidad separa productos clinicamente distintos; 'no esteril' debe evaluarse antes que 'esteril'."
    },
    {
      "name": "desechable",
      "role": "identity",
      "domain": [
        "desechable",
        "reutilizable"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bdesechable\\w*\\b|\\bdescartable\\w*\\b",
          "value": "desechable"
        },
        {
          "kind": "keyword",
          "pattern": "\\breutilizable\\w*\\b|\\blavanderia\\b",
          "value": "reutilizable"
        }
      ],
      "curation_notes": "Identity: desechable vs reutilizable son productos distintos; 'confeccion externa para servicio de lavanderia' implica reutilizable (tela)."
    },
    {
      "name": "talla",
      "role": "identity",
      "domain": [
        "talla_xs",
        "talla_s",
        "talla_m",
        "talla_l",
        "talla_xl",
        "talla_xxl",
        "talla_unica",
        "n_2",
        "n_4",
        "n_6",
        "n_8",
        "n_10",
        "n_12",
        "n_14",
        "t_46",
        "t_48",
        "t_50",
        "t_52",
        "t_54",
        "t_56",
        "t_58",
        "t_60"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\btalla\\s+(?:unica|standar|standard|standar\\w*)\\b",
          "value": "talla_unica"
        },
        {
          "kind": "regex",
          "pattern": "\\btalla\\s+n\\s+(\\d{1,2})\\b",
          "template": "n_{1}"
        },
        {
          "kind": "regex",
          "pattern": "\\bt\\s+(\\d{2})\\b",
          "template": "t_{1}"
        },
        {
          "kind": "regex",
          "pattern": "\\b(?:talla|tallas|tamano)\\s+(xxl|xl|xs|s|m|l)\\b",
          "template": "talla_{1}"
        }
      ],
      "curation_notes": "Identity: la talla discrimina unidades distintas; conviven sistema letras (xs-xxl), pediatrico (n_2..n_14) y numerico de tela (t_46..t_60), mas talla_unica; reglas de mas especifica a mas general."
    },
    {
      "name": "material",
      "role": "descriptive",
      "domain": [
        "sms",
        "poliester",
        "plastico",
        "algodon",
        "trevira",
        "crea",
        "tela"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bsms\\b",
          "value": "sms"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpoliester\\b",
          "value": "poliester"
        },
        {
          "kind": "keyword",
          "pattern": "\\bplastic\\w*\\b",
          "value": "plastico"
        },
        {
          "kind": "keyword",
          "pattern": "\\btrevira\\b",
          "value": "trevira"
        },
        {
          "kind": "keyword",
          "pattern": "\\balgodon\\b",
          "value": "algodon"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcrea\\b",
          "value": "crea"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgenero\\b|\\btela\\b",
          "value": "tela"
        }
      ],
      "curation_notes": "Descriptive: se normaliza el material cuando aparece pero es escaso y no se usa en la igualdad; reglas ordenadas de mas especifica (marca/tejido) a mas generica (tela/genero)."
    },
    {
      "name": "manga",
      "role": "descriptive",
      "domain": [
        "manga_larga",
        "manga_corta",
        "manga_3_4"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bmanga\\s+3\\s+4\\b",
          "value": "manga_3_4"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmanga\\s+larga\\b|\\bmangas?\\s+largas?\\b",
          "value": "manga_larga"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmanga\\s+corta\\b|\\bmangas?\\s+cortas?\\b",
          "value": "manga_corta"
        }
      ],
      "curation_notes": "Descriptive: el largo de manga se normaliza para enriquecer la ficha pero no fija identidad; '3 4' (tres cuartos) antes que larga/corta."
    }
  ]
}