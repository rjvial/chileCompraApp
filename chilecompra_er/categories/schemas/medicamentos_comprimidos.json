    {
      "name": "concentracion",
      "role": "identity",
      "domain": [
        "0.25mg",
        "0.5mg",
        "1mg",
        "2mg",
        "2.5mg",
        "3mg",
        "4mg",
        "5mg",
        "10mg",
        "12.5mg",
        "15mg",
        "20mg",
        "25mg",
        "30mg",
        "40mg",
        "50mg",
        "60mg",
        "75mg",
        "80mg",
        "100mg",
        "125mg",
        "150mg",
        "160mg",
        "200mg",
        "250mg",
        "300mg",
        "400mg",
        "500mg",
        "600mg",
        "850mg",
        "875mg",
        "1000mg"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d+(?:\\.\\d+)?)\\s*mg\\b",
          "template": "{1}mg"
        }
      ],
      "curation_notes": "Identity: la dosis discrimina presentaciones del mismo farmaco (atorvastatina 10mg vs 40mg). Dominio generoso de potencias estandar en mg. En combinaciones de dosis multiples gana el primer valor capturado dentro del dominio; revisar manualmente combos.",
      "unit": "mg"
    },
    {
      "name": "forma_administracion",
      "role": "identity",
      "domain": [
        "oral",
        "sublingual",
        "masticable"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bsublingual\\b",
          "value": "sublingual"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmasticable\\b",
          "value": "masticable"
        },
        {
          "kind": "keyword",
          "pattern": "via oral",
          "value": "oral"
        }
      ],
      "curation_notes": "Identity: la via/forma de administracion modifica el efecto clinico (sublingual y masticable no son intercambiables con el oral deglutido). Ausencia se asume oral pero solo se fija si aparece explicito."
    },
    {
      "name": "liberacion",
      "role": "identity",
      "domain": [
        "inmediata",
        "prolongada"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bretard\\b",
          "value": "prolongada"
        }
      ],
      "curation_notes": "Identity: la liberacion modificada (retard) no es bioequivalente a la inmediata, por lo que discrimina identidad. Solo se fija prolongada cuando aparece marcador explicito; sin marcador queda nulo."
    },
    {
      "name": "recubrimiento",
      "role": "descriptive",
      "domain": [
        "recubierto",
        "ranurado"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "recubierto",
          "value": "recubierto"
        },
        {
          "kind": "keyword",
          "pattern": "ranurado",
          "value": "ranurado"
        }
      ],
      "curation_notes": "Descriptive: el recubrimiento o ranurado se normaliza pero no altera la identidad terapeutica (comprimido vs comprimido recubierto del mismo farmaco/dosis son equivalentes); nunca participa en la igualdad."
    }
