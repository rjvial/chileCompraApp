{
  "category_id": "cables_interfaz_monitores",
  "name": "Cables e interfaz para monitores y equipos medicos",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 cable)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo_cable': 0.38, 'compatibilidad_marca': 0.3, 'conexion': 0.04, 'longitud': 0.06}, illegal extractions 0.",
    "Fix-D part2: numeric domains regenerated — canonicalized to one unit, leading zeros normalized, corpus-observed values (>=25) added."
  ],
  "attribute_defs": [
    {
      "name": "tipo_cable",
      "role": "identity",
      "domain": [
        "interfaz",
        "paciente",
        "ecg",
        "electrodo",
        "bipolar",
        "presion_invasiva",
        "troncal",
        "leadwire",
        "guia",
        "tens",
        "sensor_spo2"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "presion invasiva|linea arterial invasiva",
          "value": "presion_invasiva"
        },
        {
          "kind": "keyword",
          "pattern": "spo\\s*2|oximetr|oximax",
          "value": "sensor_spo2"
        },
        {
          "kind": "keyword",
          "pattern": "lead\\s*wire|leadwire|leads set",
          "value": "leadwire"
        },
        {
          "kind": "keyword",
          "pattern": "troncal",
          "value": "troncal"
        },
        {
          "kind": "keyword",
          "pattern": "bipolar",
          "value": "bipolar"
        },
        {
          "kind": "keyword",
          "pattern": "electrodo",
          "value": "electrodo"
        },
        {
          "kind": "keyword",
          "pattern": "\\btens\\b",
          "value": "tens"
        },
        {
          "kind": "keyword",
          "pattern": "\\becg\\b|electrocardiograf",
          "value": "ecg"
        },
        {
          "kind": "keyword",
          "pattern": "interfaz",
          "value": "interfaz"
        },
        {
          "kind": "keyword",
          "pattern": "cable guia",
          "value": "guia"
        },
        {
          "kind": "keyword",
          "pattern": "paciente",
          "value": "paciente"
        }
      ],
      "curation_notes": "Identity: el tipo funcional del cable discrimina productos dentro de la categoria (interfaz vs paciente vs presion invasiva vs bipolar, etc.); dominio cerrado segun los tipos observados, reglas de mas especifica (presion invasiva, spo2, leadwire) a mas general (paciente)."
    },
    {
      "name": "compatibilidad_marca",
      "role": "identity",
      "domain": [
        "mindray",
        "general_electric",
        "spacelabs",
        "welch_allyn",
        "nihon_koden",
        "draeger",
        "alcon",
        "cadwell",
        "grass",
        "massimo"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "general electric",
          "value": "general_electric"
        },
        {
          "kind": "keyword",
          "pattern": "welch allyn",
          "value": "welch_allyn"
        },
        {
          "kind": "keyword",
          "pattern": "nihon koden",
          "value": "nihon_koden"
        },
        {
          "kind": "keyword",
          "pattern": "mindray",
          "value": "mindray"
        },
        {
          "kind": "keyword",
          "pattern": "spacelabs",
          "value": "spacelabs"
        },
        {
          "kind": "keyword",
          "pattern": "drager|draeger|draguer",
          "value": "draeger"
        },
        {
          "kind": "keyword",
          "pattern": "alcon",
          "value": "alcon"
        },
        {
          "kind": "keyword",
          "pattern": "cadwell",
          "value": "cadwell"
        },
        {
          "kind": "keyword",
          "pattern": "grass",
          "value": "grass"
        },
        {
          "kind": "keyword",
          "pattern": "mas+imo",
          "value": "massimo"
        }
      ],
      "curation_notes": "Identity: un cable de monitor/equipo se identifica por la marca de equipo a la que conecta (un cable para spacelabs no equivale a uno para mindray); dominio cerrado de marcas observadas, normalizando el typo 'draguer'->draeger."
    },
    {
      "name": "conexion",
      "role": "identity",
      "domain": [
        "2_pin",
        "3_pin",
        "4_pin",
        "5_pin",
        "6_pin",
        "12_pin",
        "2_pares",
        "3_pares",
        "5_pares",
        "10_pares"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*pin\\b",
          "template": "{1}_pin"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*pares\\b",
          "template": "{1}_pares"
        }
      ],
      "curation_notes": "Identity: el numero de pines o pares del conector distingue variantes compatibles (bipolar 2 pin vs tens 5 pares); dominio cerrado con los conteos estandar observados y comunes del rubro."
    },
    {
      "name": "longitud",
      "role": "descriptive",
      "domain": [
        "1.5m",
        "2m",
        "3m",
        "10ft",
        "12ft"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d+(?:\\.\\d+)?)\\s*mts\\b",
          "template": "{1}m"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d+(?:\\.\\d+)?)\\s*ft\\b",
          "template": "{1}ft"
        }
      ],
      "curation_notes": "Descriptive: la longitud aparece de forma esporadica (1.5 mts, 12 ft) y se normaliza pero no se usa para la igualdad por su baja cobertura y unidades mixtas."
    }
  ]
}
