{
  "category_id": "ferulas",
  "name": "Ferulas (ortesis inmovilizadoras)",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 ferula)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 0.66, 'material': 0.34, 'ancho': 0.44, 'largo': 0.34, 'poblacion': 0.2, 'talla': 0.1}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "digital",
        "nasal",
        "munequera",
        "semirigida",
        "palmar",
        "dorsaleta",
        "abanico_palmeta"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bnasal\\b",
          "value": "nasal"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmunequera\\b",
          "value": "munequera"
        },
        {
          "kind": "keyword",
          "pattern": "dorsaleta",
          "value": "dorsaleta"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpalmar\\b",
          "value": "palmar"
        },
        {
          "kind": "keyword",
          "pattern": "abanico|palmeta",
          "value": "abanico_palmeta"
        },
        {
          "kind": "keyword",
          "pattern": "semi\\s*rigida",
          "value": "semirigida"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdigital\\b",
          "value": "digital"
        }
      ],
      "curation_notes": "identity: la forma/region anatomica de la ferula (digital, nasal, munequera, semirigida, palmar, dorsaleta, abanico/palmeta) distingue productos distintos; dominio cerrado segun tipos observados."
    },
    {
      "name": "material",
      "role": "identity",
      "domain": [
        "aluminio",
        "metalica",
        "termoplastico",
        "neopreno",
        "silicona",
        "espuma"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\balum",
          "value": "aluminio"
        },
        {
          "kind": "keyword",
          "pattern": "termoplastico",
          "value": "termoplastico"
        },
        {
          "kind": "keyword",
          "pattern": "neopreno",
          "value": "neopreno"
        },
        {
          "kind": "keyword",
          "pattern": "silicona",
          "value": "silicona"
        },
        {
          "kind": "keyword",
          "pattern": "espuma|moltopren",
          "value": "espuma"
        },
        {
          "kind": "keyword",
          "pattern": "metalic",
          "value": "metalica"
        }
      ],
      "curation_notes": "identity: el material base (aluminio moldeable, termoplastico, neopreno, silicona, metalica) define un producto distinto; aluminio antes que metalica/espuma porque es el material nucleo cuando coexisten."
    },
    {
      "name": "ancho",
      "role": "identity",
      "domain": [
        "1cm",
        "1.3cm",
        "1.5cm",
        "2cm",
        "2.5cm"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\b2\\.5\\b",
          "value": "2.5cm",
          "requires": "\\bcm\\b|ancho|ferula"
        },
        {
          "kind": "keyword",
          "pattern": "\\b1\\.5\\b",
          "value": "1.5cm",
          "requires": "\\bcm\\b|ancho|ferula"
        },
        {
          "kind": "keyword",
          "pattern": "\\b13\\s*mm\\b",
          "value": "1.3cm"
        },
        {
          "kind": "keyword",
          "pattern": "\\b2(?:\\.0)?\\s*x\\s*3|x\\s*2(?:\\.0)?\\s*cm|\\b2(?:\\.0)?\\s*cm\\s*ancho|\\b20\\s*mm\\b",
          "value": "2cm"
        },
        {
          "kind": "keyword",
          "pattern": "\\b1\\s*cm\\s*x|\\b1\\s*x\\s*30",
          "value": "1cm"
        }
      ],
      "curation_notes": "identity: el ancho de la ferula digital (1, 1.5, 2, 2.5 cm; 13/20 mm) es el discriminador dimensional principal; reglas de mas especifica (2.5/1.5) a mas general para no confundir 1.5 con 1 o 2.",
      "unit": "cm"
    },
    {
      "name": "largo",
      "role": "descriptive",
      "domain": [
        "20cm",
        "30cm"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bx\\s*30\\b|\\b30\\s*x\\b|30\\s*cm\\s*largo",
          "value": "30cm"
        },
        {
          "kind": "keyword",
          "pattern": "\\bx\\s*20\\b",
          "value": "20cm"
        }
      ],
      "curation_notes": "descriptive: el largo es casi siempre 30 cm (estandar), aporta poca discriminacion frente al ancho; se normaliza pero no fija identidad.",
      "unit": "cm"
    },
    {
      "name": "poblacion",
      "role": "descriptive",
      "domain": [
        "adulto",
        "pediatrico"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "pediatric|\\bnino\\b",
          "value": "pediatrico"
        },
        {
          "kind": "keyword",
          "pattern": "\\badulto\\b",
          "value": "adulto"
        }
      ],
      "curation_notes": "descriptive: adulto/pediatrico suele estar implicito en la medida (ancho) por lo que no se usa para igualdad; se normaliza como referencia."
    },
    {
      "name": "talla",
      "role": "descriptive",
      "domain": [
        "talla_s",
        "talla_m",
        "talla_l",
        "talla_4",
        "grande"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "talla\\s*4|\\bmallet\\b",
          "value": "talla_4"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgrande\\b",
          "value": "grande"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla\\s*l\\b",
          "value": "talla_l"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla\\s*m\\b|\\bdedo\\s*m\\b",
          "value": "talla_m"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla\\s*s\\b",
          "value": "talla_s"
        }
      ],
      "curation_notes": "descriptive: tallas aparecen de forma escasa e inconsistente (s/m/l, talla 4 mallet, grande) y mezclan semanticas; se normalizan pero no participan en la igualdad."
    }
  ]
}
