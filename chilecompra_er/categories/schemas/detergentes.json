{
  "category_id": "detergentes",
  "name": "Detergentes y limpiadores",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 envase)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 0.62, 'forma': 0.34, 'ph': 0.28, 'capacidad': 0.66, 'uso': 0.58}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "enzimatico",
        "desinfectante",
        "desincrustante",
        "desengrasante",
        "lavavajillas",
        "suavizante",
        "prelavado",
        "clorado"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "enzimat",
          "value": "enzimatico"
        },
        {
          "kind": "keyword",
          "pattern": "desincrust|descincrust",
          "value": "desincrustante"
        },
        {
          "kind": "keyword",
          "pattern": "desengras|desengraz",
          "value": "desengrasante"
        },
        {
          "kind": "keyword",
          "pattern": "lavaloza|lavavajilla",
          "value": "lavavajillas"
        },
        {
          "kind": "keyword",
          "pattern": "suavizante",
          "value": "suavizante"
        },
        {
          "kind": "keyword",
          "pattern": "pre lavado|prelavado|prelavado",
          "value": "prelavado"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcloro\\b|clorado",
          "value": "clorado"
        },
        {
          "kind": "keyword",
          "pattern": "desinfectante",
          "value": "desinfectante"
        }
      ],
      "curation_notes": "Clase funcional del producto; discrimina identidad (un enzimatico no es lo mismo que un lavavajillas o un desincrustante). Dominio cerrado de funciones observadas; orden de especifico a general (desinfectante al final)."
    },
    {
      "name": "forma",
      "role": "identity",
      "domain": [
        "polvo",
        "liquido",
        "spray",
        "gel",
        "espuma"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "polvo",
          "value": "polvo"
        },
        {
          "kind": "keyword",
          "pattern": "spray|rociador",
          "value": "spray"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgel\\b",
          "value": "gel"
        },
        {
          "kind": "keyword",
          "pattern": "espuma",
          "value": "espuma"
        },
        {
          "kind": "keyword",
          "pattern": "liquid[oa]",
          "value": "liquido"
        }
      ],
      "curation_notes": "Estado fisico del producto; polvo vs liquido vs spray es una diferencia real de SKU. Orden de especifico a general (liquido al final por ser el mas amplio)."
    },
    {
      "name": "ph",
      "role": "identity",
      "domain": [
        "neutro",
        "alcalino",
        "acido"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "neutro",
          "value": "neutro"
        },
        {
          "kind": "keyword",
          "pattern": "alcalino|\\balc\\b",
          "value": "alcalino"
        },
        {
          "kind": "keyword",
          "pattern": "acido",
          "value": "acido"
        }
      ],
      "curation_notes": "Caracter quimico (neutro/alcalino/acido); discrimina identidad por compatibilidad de uso y formulacion. Dominio cerrado estandar del rubro; null cuando no se menciona."
    },
    {
      "name": "capacidad",
      "role": "identity",
      "domain": [
        "30ml",
        "50g",
        "250ml",
        "400g",
        "500ml",
        "650ml",
        "750ml",
        "1kg",
        "1l",
        "1.9l",
        "2l",
        "3.78l",
        "5l",
        "10kg",
        "20kg",
        "21l"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,4})\\s*cc\\b",
          "template": "{1}ml"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,4})\\s*ml\\b",
          "template": "{1}ml"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2}(?:\\.\\d+)?)\\s*l(?:t|ts|tr|itro|itros)?\\b",
          "template": "{1}l"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,3}(?:\\.\\d+)?)\\s*k(?:g|ilo|ilos|ilogramos?)?\\b",
          "template": "{1}kg"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{2,4})\\s*g(?:r|rs|ramos?)?\\b",
          "template": "{1}g"
        }
      ],
      "curation_notes": "Contenido del envase (volumen o masa del producto, no empaque caja x N); discrimina identidad porque mismo detergente en distinto formato es otro SKU. Dominio cerrado de formatos observados; reglas de especifico (cc, ml) a general; cc se canoniza a ml."
    },
    {
      "name": "uso",
      "role": "descriptive",
      "domain": [
        "instrumental_quirurgico",
        "superficies",
        "ropa",
        "loza",
        "laboratorio",
        "frutas_verduras"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "instrumental|quirurgic|endoscop|esterilizacion|termodesinfect",
          "value": "instrumental_quirurgico"
        },
        {
          "kind": "keyword",
          "pattern": "frutas|verduras",
          "value": "frutas_verduras"
        },
        {
          "kind": "keyword",
          "pattern": "lavaloza|lavavajilla|\\bloza\\b",
          "value": "loza"
        },
        {
          "kind": "keyword",
          "pattern": "\\bropa\\b|lavanderia",
          "value": "ropa"
        },
        {
          "kind": "keyword",
          "pattern": "laboratorio",
          "value": "laboratorio"
        },
        {
          "kind": "keyword",
          "pattern": "superficie|pisos|paredes|bano",
          "value": "superficies"
        }
      ],
      "curation_notes": "Ambito de aplicacion declarado; se normaliza para contexto pero no fija identidad (el mismo producto puede listarse con usos distintos). Orden de especifico a general."
    }
  ]
}