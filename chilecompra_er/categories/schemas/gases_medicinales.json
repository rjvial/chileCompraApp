{
  "category_id": "gases_medicinales",
  "name": "Gases medicinales/clínicos",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 articulo)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo_articulo': 1.0, 'tipo_gas': 0.54, 'capacidad': 0.1, 'norma_conexion': 0.24, 'material': 0.08, 'marca': 0.2}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo_articulo",
      "role": "identity",
      "domain": [
        "gas",
        "toma",
        "flujometro",
        "conector",
        "conexion_yugo",
        "regulador",
        "frasco_aspiracion",
        "humidificador",
        "golilla",
        "teflon",
        "bomba_vacio",
        "red",
        "servicio_mantencion"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "bomba\\s+de\\s+vacio",
          "value": "bomba_vacio"
        },
        {
          "kind": "keyword",
          "pattern": "frasco\\s+(?:de\\s+)?aspiracion",
          "value": "frasco_aspiracion"
        },
        {
          "kind": "keyword",
          "pattern": "conexion\\s+yugo",
          "value": "conexion_yugo"
        },
        {
          "kind": "keyword",
          "pattern": "\\btoma\\b",
          "value": "toma"
        },
        {
          "kind": "keyword",
          "pattern": "\\bflujometro\\b",
          "value": "flujometro"
        },
        {
          "kind": "keyword",
          "pattern": "\\bregulador(?:es)?\\b",
          "value": "regulador"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhumidificador\\b",
          "value": "humidificador"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgolilla\\b",
          "value": "golilla"
        },
        {
          "kind": "keyword",
          "pattern": "\\bteflon\\b",
          "value": "teflon"
        },
        {
          "kind": "keyword",
          "pattern": "\\bconector(?:es)?\\b",
          "value": "conector"
        },
        {
          "kind": "keyword",
          "pattern": "\\bredes?\\b",
          "value": "red"
        },
        {
          "kind": "keyword",
          "pattern": "manten(?:cion|imiento)",
          "value": "servicio_mantencion"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgas(?:es)?\\b",
          "value": "gas"
        }
      ],
      "curation_notes": "Identity: tipo de articulo es el discriminador principal de esta categoria mixta (gas a granel vs componente de red vs servicio); dominio cerrado derivado de las descripciones."
    },
    {
      "name": "tipo_gas",
      "role": "identity",
      "domain": [
        "oxigeno",
        "nitrogeno",
        "oxido_nitroso",
        "dioxido_carbono",
        "helio",
        "aire",
        "mezcla"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "oxido\\s+nitroso",
          "value": "oxido_nitroso"
        },
        {
          "kind": "keyword",
          "pattern": "dioxido\\s+de\\s+carbono",
          "value": "dioxido_carbono"
        },
        {
          "kind": "keyword",
          "pattern": "anhidrido",
          "value": "dioxido_carbono"
        },
        {
          "kind": "keyword",
          "pattern": "\\boxigeno\\b",
          "value": "oxigeno"
        },
        {
          "kind": "keyword",
          "pattern": "\\bnitrogeno\\b",
          "value": "nitrogeno"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhelio\\b",
          "value": "helio"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmezcla\\b",
          "value": "mezcla"
        },
        {
          "kind": "keyword",
          "pattern": "\\baire\\b",
          "value": "aire"
        }
      ],
      "curation_notes": "Identity: el gas asociado distingue tanto cilindros como tomas/conectores ('toma de oxigeno' vs 'toma de aire'); reglas especificas (oxido nitroso, dioxido) antes que las generales."
    },
    {
      "name": "capacidad",
      "role": "identity",
      "domain": [
        "3.22m3",
        "8m3",
        "8.5m3",
        "10m3",
        "6m3",
        "30kg",
        "50kg"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d+(?:\\.\\d+)?)\\s*m\\s*3\\b",
          "template": "{1}m3"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d+(?:\\.\\d+)?)\\s*kg\\b",
          "template": "{1}kg"
        }
      ],
      "curation_notes": "Identity para gases a granel: volumen (m3) o masa (kg) del cilindro distingue presentaciones; dominio observado mas tamanos estandar de cilindro."
    },
    {
      "name": "norma_conexion",
      "role": "descriptive",
      "domain": [
        "aga",
        "diss",
        "npt"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bdiss\\b",
          "value": "diss"
        },
        {
          "kind": "keyword",
          "pattern": "\\bnpt\\b",
          "value": "npt"
        },
        {
          "kind": "keyword",
          "pattern": "\\baga\\b",
          "value": "aga"
        }
      ],
      "curation_notes": "Descriptive: norma/estandar de conexion (aga, diss, npt) se normaliza pero es atributo de detalle de componentes, no de identidad del producto."
    },
    {
      "name": "material",
      "role": "descriptive",
      "domain": [
        "policarbonato",
        "plastico",
        "teflon"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "policarbonato",
          "value": "policarbonato"
        },
        {
          "kind": "keyword",
          "pattern": "\\bteflon\\b",
          "value": "teflon"
        },
        {
          "kind": "keyword",
          "pattern": "\\bplastico\\b",
          "value": "plastico"
        }
      ],
      "curation_notes": "Descriptive: material del componente (policarbonato, plastico, teflon) aporta detalle pero no define la identidad."
    },
    {
      "name": "marca",
      "role": "descriptive",
      "domain": [
        "ohio",
        "diamond",
        "hudson",
        "harris"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bohio\\b",
          "value": "ohio"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdiamond\\b",
          "value": "diamond"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhudson\\b",
          "value": "hudson"
        },
        {
          "kind": "keyword",
          "pattern": "\\bharris\\b",
          "value": "harris"
        }
      ],
      "curation_notes": "Descriptive: marca del fabricante (ohio, diamond, hudson, harris) se normaliza como referencia, nunca participa en la igualdad."
    }
  ]
}