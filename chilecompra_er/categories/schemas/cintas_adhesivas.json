{
  "category_id": "cintas_adhesivas",
  "name": "Cintas adhesivas y engomadas",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 rollo de cinta)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 0.82, 'material': 0.34, 'color': 0.44, 'ancho': 0.18, 'largo': 0.18}, illegal extractions 4.",
    "Fix-D part2: numeric domains regenerated — canonicalized to one unit, leading zeros normalized, corpus-observed values (>=25) added."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "control_quimico",
        "marcado_instrumental",
        "reactiva",
        "quirurgica",
        "masking",
        "embalaje",
        "refuerzo"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "control\\s+quimico|autoclav|control\\s+de\\s+esterilizacion|oxido\\s+etileno|bowie\\s+dick",
          "value": "control_quimico"
        },
        {
          "kind": "keyword",
          "pattern": "marcado\\s+de\\s+instrumental|p\\s+marcado|para\\s+marcado|pmarcado",
          "value": "marcado_instrumental"
        },
        {
          "kind": "keyword",
          "pattern": "reactiv|test\\s+de\\s+glucosa|glicemia|glucosa|colesterol|cinta\\s+test|tiras|determinacion|medicion\\s+de\\s+ph|combur",
          "value": "reactiva"
        },
        {
          "kind": "keyword",
          "pattern": "quirurgica|medica|micropore|microporos|suburetral|refuerzo\\s+adhesiva",
          "value": "quirurgica"
        },
        {
          "kind": "keyword",
          "pattern": "masking|maskim|maskin|enmascarar|engomad",
          "value": "masking"
        },
        {
          "kind": "keyword",
          "pattern": "embalaje|envasado|envolturas|sellado\\s+de\\s+juntas|densoband",
          "value": "embalaje"
        },
        {
          "kind": "keyword",
          "pattern": "refuerzo|cinta\\s+de\\s+fibra|reinforcement|cinta\\s+articular",
          "value": "refuerzo"
        }
      ],
      "curation_notes": "identity: la funcion del producto separa familias incompatibles (indicador de esterilizacion vs cinta de marcado vs tira reactiva vs cinta quirurgica vs masking vs embalaje vs refuerzo); reglas ordenadas de mas especifica a mas general."
    },
    {
      "name": "material",
      "role": "identity",
      "domain": [
        "pvc",
        "papel",
        "tela",
        "plastico",
        "transparente"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bpvc\\b",
          "value": "pvc"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpapel\\b|micropore|microporos",
          "value": "papel"
        },
        {
          "kind": "keyword",
          "pattern": "\\btela\\b|tejido|fibra|no\\s+tejido",
          "value": "tela"
        },
        {
          "kind": "keyword",
          "pattern": "plastic",
          "value": "plastico"
        },
        {
          "kind": "keyword",
          "pattern": "transparente|transp\\b",
          "value": "transparente"
        }
      ],
      "curation_notes": "identity: el sustrato (pvc, papel/microporoso, tela, plastico) define identidad y compatibilidad de uso; transparente como ultimo recurso cuando solo se indica acabado."
    },
    {
      "name": "color",
      "role": "identity",
      "domain": [
        "transparente",
        "blanco",
        "verde",
        "rojo",
        "azul",
        "amarillo",
        "naranja",
        "negro",
        "violeta",
        "cafe",
        "piel",
        "amarilla"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bpiel\\b",
          "value": "piel"
        },
        {
          "kind": "keyword",
          "pattern": "\\bverde\\b",
          "value": "verde"
        },
        {
          "kind": "keyword",
          "pattern": "\\brojo\\b|\\broja\\b",
          "value": "rojo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bazul\\b",
          "value": "azul"
        },
        {
          "kind": "keyword",
          "pattern": "\\bamarillo\\b|\\bamarilla\\b",
          "value": "amarillo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bnaranja\\b",
          "value": "naranja"
        },
        {
          "kind": "keyword",
          "pattern": "\\bnegro\\b|\\bnegra\\b",
          "value": "negro"
        },
        {
          "kind": "keyword",
          "pattern": "\\bvioleta\\b",
          "value": "violeta"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcafe\\b",
          "value": "cafe"
        },
        {
          "kind": "keyword",
          "pattern": "\\bblanco\\b|\\bblanca\\b",
          "value": "blanco"
        },
        {
          "kind": "keyword",
          "pattern": "transparente|transp\\b",
          "value": "transparente"
        }
      ],
      "curation_notes": "identity: en las cintas de marcado de instrumental el color ES el unico discriminador del producto; domino cerrado a colores observados."
    },
    {
      "name": "ancho",
      "role": "identity",
      "domain": [
        "1.5mm",
        "2.5mm",
        "3mm",
        "5mm",
        "12mm",
        "12.5mm",
        "13mm",
        "18mm",
        "19mm",
        "20mm",
        "24mm",
        "25mm",
        "30mm",
        "40mm",
        "48mm",
        "50mm",
        "60mm",
        "100mm",
        "110mm",
        "150mm",
        "200mm",
        "220mm",
        "300mm"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,3}(?:\\.\\d+)?)\\s*mm\\b",
          "template": "{1}mm"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2}(?:\\.\\d+)?)\\s*cm\\b",
          "template": "{1}cm"
        }
      ],
      "curation_notes": "identity: el ancho del rollo distingue presentaciones (18mm vs 48mm vs 2.5cm); se conserva la unidad observada (mm/cm) por no poder convertir en plantilla.",
      "unit": "mm"
    },
    {
      "name": "largo",
      "role": "identity",
      "domain": [
        "5m",
        "9m",
        "9.1m",
        "9.14m",
        "10m",
        "25m",
        "30m",
        "40m",
        "45m",
        "50m",
        "55m",
        "91m"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,3}(?:\\.\\d+)?)\\s*(?:metros|mts|mt|m)\\b",
          "template": "{1}m"
        }
      ],
      "curation_notes": "identity: el largo del rollo separa presentaciones de igual ancho (50m vs 9.1m); domino cerrado a largos estandar observados.",
      "unit": "m"
    }
  ]
}
