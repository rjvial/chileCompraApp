{
  "category_id": "ecografos",
  "name": "Ecografos",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 ecografo)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 1.0, 'aplicacion': 0.28, 'portabilidad': 0.06, 'ancho': 0.12, 'marca': 0.26}, illegal extractions 0.",
    "Fix-D part2: numeric domains regenerated — canonicalized to one unit, leading zeros normalized, corpus-observed values (>=25) added."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "ecografo",
        "papel",
        "funda",
        "transductor",
        "cateter",
        "aguja",
        "accesorio"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bpapel\\b",
          "value": "papel"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfundas?\\b",
          "value": "funda"
        },
        {
          "kind": "keyword",
          "pattern": "\\btransductor",
          "value": "transductor"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcateter",
          "value": "cateter"
        },
        {
          "kind": "keyword",
          "pattern": "\\baguja\\b",
          "value": "aguja"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhub\\b|\\bknobs\\b|\\baccesorio",
          "value": "accesorio"
        },
        {
          "kind": "keyword",
          "pattern": "\\becografo",
          "value": "ecografo"
        }
      ],
      "curation_notes": "Identity: separa el equipo (ecografo) de consumibles/accesorios (papel, funda, cateter, aguja, transductor, hub) que comparten la palabra ecografo pero no son el mismo producto; dominio cerrado a los tipos observados."
    },
    {
      "name": "aplicacion",
      "role": "identity",
      "domain": [
        "ginecologico",
        "obstetrico",
        "cardiologico",
        "oftalmico",
        "anestesia",
        "urgencia",
        "multiproposito",
        "nefrologia",
        "maternal",
        "vascular"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bmultiproposito\\b",
          "value": "multiproposito"
        },
        {
          "kind": "keyword",
          "pattern": "\\bginecolog",
          "value": "ginecologico"
        },
        {
          "kind": "keyword",
          "pattern": "\\bobstetr",
          "value": "obstetrico"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcardiolog|\\bcardio\\b|\\bintracardiaca\\b",
          "value": "cardiologico"
        },
        {
          "kind": "keyword",
          "pattern": "\\boftalmico\\b|\\bocular\\b",
          "value": "oftalmico"
        },
        {
          "kind": "keyword",
          "pattern": "\\banestesia\\b",
          "value": "anestesia"
        },
        {
          "kind": "keyword",
          "pattern": "\\burgencia\\b",
          "value": "urgencia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bnefrolog|\\bnegrolog",
          "value": "nefrologia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmaternal\\b",
          "value": "maternal"
        },
        {
          "kind": "keyword",
          "pattern": "\\bvascular\\b",
          "value": "vascular"
        }
      ],
      "curation_notes": "Identity: la especialidad clinica del ecografo distingue equipos para usos distintos (ginecologico vs cardiologico vs oftalmico, etc.); dominio cerrado a las especialidades observadas, incluyendo el typo negrologia mapeado a nefrologia."
    },
    {
      "name": "portabilidad",
      "role": "identity",
      "domain": [
        "portatil",
        "inalambrico"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\binalambrico\\b",
          "value": "inalambrico"
        },
        {
          "kind": "keyword",
          "pattern": "\\bportatil",
          "value": "portatil"
        }
      ],
      "curation_notes": "Identity: un ecografo portatil o inalambrico es un producto distinto de uno fijo de policlinico; dominio cerrado a los dos rasgos observados."
    },
    {
      "name": "ancho",
      "role": "identity",
      "domain": [
        "63mm",
        "110mm"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(110|63)\\s*mm\\b",
          "template": "{1}mm"
        }
      ],
      "curation_notes": "Identity: para el papel de impresion el ancho del rollo distingue formatos (110 mm vs 63 mm); regex acotada a los anchos observados para evitar capturar el diametro del nucleo (int 16 mm) u otras medidas.",
      "unit": "mm"
    },
    {
      "name": "marca",
      "role": "descriptive",
      "domain": [
        "ge",
        "philips",
        "sony",
        "mindray",
        "toshiba",
        "siemens"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bgeneral electric\\b|\\bge\\b",
          "value": "ge"
        },
        {
          "kind": "keyword",
          "pattern": "\\bphilips\\b",
          "value": "philips"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsony\\b",
          "value": "sony"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmindray\\b",
          "value": "mindray"
        },
        {
          "kind": "keyword",
          "pattern": "\\btoshiba\\b",
          "value": "toshiba"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsiemens\\b",
          "value": "siemens"
        }
      ],
      "curation_notes": "Descriptive: la marca se normaliza para enriquecer pero no decide igualdad (el modelo, no la marca, fijaria identidad fina); dominio cerrado a las marcas observadas."
    }
  ]
}
