{
  "category_id": "ecografos",
  "name": "Ecógrafos",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 ecografo)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'aplicacion': 0.2, 'portabilidad': 0.06, 'marca': 0.26}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "aplicacion",
      "role": "identity",
      "domain": [
        "ginecologico",
        "obstetrico",
        "cardiologico",
        "anestesia",
        "oftalmico",
        "urgencia",
        "multiproposito",
        "vascular",
        "nefrologico",
        "general"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bmultiproposito\\b",
          "value": "multiproposito"
        },
        {
          "kind": "keyword",
          "pattern": "\\bginecolog",
          "value": "ginecologico"
        },
        {
          "kind": "keyword",
          "pattern": "\\bobstetr",
          "value": "obstetrico"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcardiolog",
          "value": "cardiologico"
        },
        {
          "kind": "keyword",
          "pattern": "\\banestesia\\b",
          "value": "anestesia"
        },
        {
          "kind": "keyword",
          "pattern": "\\boftalmic",
          "value": "oftalmico"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(nefrolog|negrolog)",
          "value": "nefrologico"
        },
        {
          "kind": "keyword",
          "pattern": "\\bvascular\\b",
          "value": "vascular"
        },
        {
          "kind": "keyword",
          "pattern": "\\burgencia\\b",
          "value": "urgencia"
        }
      ],
      "curation_notes": "Especialidad/aplicacion clinica que distingue el equipo (ginecologico vs cardiologico vs oftalmico, etc.); dominio cerrado a las especialidades observadas + 'general'."
    },
    {
      "name": "portabilidad",
      "role": "identity",
      "domain": [
        "portatil",
        "inalambrico",
        "fijo"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\binalambric",
          "value": "inalambrico"
        },
        {
          "kind": "keyword",
          "pattern": "\\bportatil",
          "value": "portatil"
        }
      ],
      "curation_notes": "Formato fisico del ecografo (portatil/inalambrico vs fijo de carro) discrimina identidad; 'fijo' es el valor por defecto cuando no hay marca de portabilidad."
    },
    {
      "name": "marca",
      "role": "descriptive",
      "domain": [
        "ge",
        "philips",
        "sony",
        "mindray",
        "toshiba",
        "siemens"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "general\\s+electric",
          "value": "ge"
        },
        {
          "kind": "keyword",
          "pattern": "\\bge\\b",
          "value": "ge"
        },
        {
          "kind": "keyword",
          "pattern": "\\bphilips\\b",
          "value": "philips"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsony\\b",
          "value": "sony"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmindray\\b",
          "value": "mindray"
        },
        {
          "kind": "keyword",
          "pattern": "\\btoshiba\\b",
          "value": "toshiba"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsiemens\\b",
          "value": "siemens"
        }
      ],
      "curation_notes": "Marca se normaliza para trazabilidad pero no define identidad del producto; dominio cerrado a las marcas observadas en el corpus."
    }
  ]
