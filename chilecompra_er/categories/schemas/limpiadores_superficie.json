{
  "category_id": "limpiadores_superficie",
  "name": "Limpiadores de piso y superficies (aseo)",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 envase)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'uso': 0.44, 'forma': 0.56, 'capacidad': 0.74, 'aroma': 0.1}, illegal extractions 1.",
    "Fix-D part2: numeric domains regenerated — canonicalized to one unit, leading zeros normalized, corpus-observed values (>=25) added."
  ],
  "attribute_defs": [
    {
      "name": "uso",
      "role": "identity",
      "domain": [
        "piso",
        "multiuso",
        "vidrios",
        "desengrasante",
        "desincrustante",
        "desinfectante",
        "bano",
        "acero_inoxidable",
        "antibacterial"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bpisos?\\b",
          "value": "piso"
        },
        {
          "kind": "keyword",
          "pattern": "\\bvidrios?\\b",
          "value": "vidrios"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:desengrasante|anti\\s*grasa|antigrasa)\\b",
          "value": "desengrasante"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:des|dis)?incrustante\\b|\\bdescincrustante\\b|\\bremovedor de sarro\\b",
          "value": "desincrustante"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:acero inoxidable|inox)\\b",
          "value": "acero_inoxidable"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbanos?\\b",
          "value": "bano"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmultiuso\\b",
          "value": "multiuso"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:desinfectante|sanitizante|algicida)\\b",
          "value": "desinfectante"
        },
        {
          "kind": "keyword",
          "pattern": "\\bantibacterial\\b",
          "value": "antibacterial"
        }
      ],
      "curation_notes": "identity: el uso/funcion (piso, multiuso, vidrios, desengrasante, desinfectante, etc.) distingue claramente entre limpiadores de la categoria; dominio cerrado a los usos observados."
    },
    {
      "name": "forma",
      "role": "identity",
      "domain": [
        "liquido",
        "crema",
        "gel",
        "spray",
        "espuma",
        "solucion",
        "polvo"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bcrema\\b",
          "value": "crema"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgel\\b",
          "value": "gel"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:spray|sprey|aerosol)\\b",
          "value": "spray"
        },
        {
          "kind": "keyword",
          "pattern": "\\bespuma\\b",
          "value": "espuma"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpolvo\\b",
          "value": "polvo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsolucion\\b",
          "value": "solucion"
        },
        {
          "kind": "keyword",
          "pattern": "\\bliquido\\b",
          "value": "liquido"
        }
      ],
      "curation_notes": "identity: el formato fisico (crema, liquido, gel, spray, espuma, solucion) separa productos distintos aunque compartan uso; dominio cerrado, regla liquido al final por ser la mas generica."
    },
    {
      "name": "capacidad",
      "role": "identity",
      "domain": [
        "30ml",
        "50g",
        "50ml",
        "100ml",
        "150ml",
        "200ml",
        "250ml",
        "300ml",
        "350ml",
        "360ml",
        "400ml",
        "450g",
        "450ml",
        "500g",
        "500ml",
        "600ml",
        "750g",
        "750ml",
        "900ml",
        "1000g",
        "1000ml",
        "2000ml",
        "5000ml"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,4})\\s*ml\\b",
          "template": "{1}ml"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,4})\\s*cc\\b",
          "template": "{1}ml"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d+(?:\\.\\d+)?)\\s*(?:litros|lts|lt|l)\\b",
          "template": "{1}l"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,4})\\s*(?:gramos|grs|gr|g)\\b",
          "template": "{1}g"
        }
      ],
      "curation_notes": "identity: la capacidad/contenido del envase distingue SKUs del mismo producto; canonico unificado en ml (cc=ml), l y g; dominio generoso sobre presentaciones estandar observadas."
    },
    {
      "name": "aroma",
      "role": "descriptive",
      "domain": [
        "lavanda",
        "eucalipto",
        "agua_marina",
        "neutro"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\blavanda\\b",
          "value": "lavanda"
        },
        {
          "kind": "keyword",
          "pattern": "\\beucaliptus?\\b|\\beucalipto\\b",
          "value": "eucalipto"
        },
        {
          "kind": "keyword",
          "pattern": "\\bagua marina\\b",
          "value": "agua_marina"
        },
        {
          "kind": "keyword",
          "pattern": "\\bneutro\\b",
          "value": "neutro"
        }
      ],
      "curation_notes": "descriptive: el aroma se normaliza pero no debe afectar la identidad del producto (un mismo limpiador viene en varios aromas)."
    }
  ]
}
