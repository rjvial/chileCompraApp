    {
      "name": "calibre",
      "role": "identity",
      "domain": [
        "1.9fr",
        "3fr",
        "3.5fr",
        "4fr",
        "4.2fr",
        "4.8fr",
        "5fr",
        "5.5fr",
        "6fr",
        "7fr",
        "8fr",
        "8.5fr",
        "10fr",
        "13.5fr",
        "18g",
        "21g",
        "22g",
        "24g"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d+(?:\\.\\d+)?)\\s*fr\\b",
          "template": "{1}fr"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*g\\b",
          "template": "{1}g"
        }
      ],
      "curation_notes": "Identidad: calibre del cateter en French (fr) o Gauge (g) discrimina tamano; se conserva la unidad en el valor canonico por coexistir ambas escalas."
    },
