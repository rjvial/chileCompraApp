          "kind": "keyword",
          "pattern": "\\bcalcaneo\\b",
          "value": "calcaneo"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalon\\b",
          "value": "talon"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfemur\\b",
          "value": "femur"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfibula\\b",
          "value": "fibula"
