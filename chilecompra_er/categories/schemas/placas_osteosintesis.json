      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\btitanio\\b",
          "value": "titanio"
        },
        {
          "kind": "keyword",
          "pattern": "\\bacero\\b",
          "value": "acero"
        }
      ],
      "curation_notes": "Descriptive: el material se normaliza pero muchas ofertas lo presentan como 'acero o titanio' (intercambiable), por lo que no fija identidad de forma confiable; dominio cerrado titanio/acero."
    }
  ]
