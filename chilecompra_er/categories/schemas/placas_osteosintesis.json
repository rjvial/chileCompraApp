{
  "category_id": "placas_osteosintesis",
  "name": "Placas de osteosíntesis",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 placa)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'segmento_anatomico': 0.46, 'calibre': 0.4, 'material': 0.28, 'tipo_fijacion': 0.38, 'forma': 0.2}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "segmento_anatomico",
      "role": "identity",
      "domain": [
        "tibia_proximal",
        "tibia_distal",
        "pilon_tibial",
        "fibula",
        "femur_distal",
        "maleolo",
        "calcaneo",
        "navicular",
        "cuboide",
        "metatarso",
        "lisfranc",
        "mediopie"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bpilon\\b",
          "value": "pilon_tibial"
        },
        {
          "kind": "keyword",
          "pattern": "tibia proximal|proximal .{0,15}tibia",
          "value": "tibia_proximal"
        },
        {
          "kind": "keyword",
          "pattern": "tibia distal|distal .{0,12}tibia",
          "value": "tibia_distal"
        },
        {
          "kind": "keyword",
          "pattern": "femur",
          "value": "femur_distal"
        },
        {
          "kind": "keyword",
          "pattern": "maleolo",
          "value": "maleolo"
        },
        {
          "kind": "keyword",
          "pattern": "fibula",
          "value": "fibula"
        },
        {
          "kind": "keyword",
          "pattern": "calcaneo|talon|seno del tarso",
          "value": "calcaneo"
        },
        {
          "kind": "keyword",
          "pattern": "lisfranc",
          "value": "lisfranc"
        },
        {
          "kind": "keyword",
          "pattern": "navicular",
          "value": "navicular"
        },
        {
          "kind": "keyword",
          "pattern": "cuboide",
          "value": "cuboide"
        },
        {
          "kind": "keyword",
          "pattern": "metatarso|metatarsiano|\\bmtt\\b",
          "value": "metatarso"
        },
        {
          "kind": "keyword",
          "pattern": "mediopie|medio pie",
          "value": "mediopie"
        }
      ],
      "curation_notes": "Identity: el segmento oseo/ubicacion anatomica es el principal discriminador entre placas de osteosintesis; dominio cerrado a las regiones observadas; pilon evaluado antes que tibia distal por especificidad."
    },
    {
      "name": "calibre",
      "role": "identity",
      "domain": [
        "1.7mm",
        "2.0mm",
        "2.3mm",
        "2.4mm",
        "2.7mm",
        "3.0mm",
        "3.2mm",
        "3.5mm",
        "4.5mm",
        "5.0mm"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b([1-5]\\.\\d)\\s*mm\\b",
          "template": "{1}mm"
        },
        {
          "kind": "regex",
          "pattern": "\\b([1-5]\\.\\d)\\b",
          "template": "{1}mm"
        }
      ],
      "curation_notes": "Identity: el calibre del sistema placa/tornillo (mm) distingue productos; muchas descripciones listan un rango (ej '2.7 3.5'), la regla captura el primer valor decimal; dominio limitado a calibres estandar observados.",
      "unit": "mm"
    },
    {
      "name": "material",
      "role": "identity",
      "domain": [
        "titanio",
        "acero"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "titanio",
          "value": "titanio"
        },
        {
          "kind": "keyword",
          "pattern": "acero|inoxidable",
          "value": "acero"
        }
      ],
      "curation_notes": "Identity: titanio vs acero es atributo clasico de identidad en implantes; titanio se evalua primero porque las descripciones dobles 'acero o titanio' suelen ofrecerse en titanio (ambiguedad a revisar en curacion)."
    },
    {
      "name": "tipo_fijacion",
      "role": "descriptive",
      "domain": [
        "bloqueada",
        "convencional"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "bloquead|\\blcp\\b|angulo variable",
          "value": "bloqueada"
        },
        {
          "kind": "keyword",
          "pattern": "convencional|no bloqueada",
          "value": "convencional"
        }
      ],
      "curation_notes": "Descriptive: bloqueo (LCP/angulo variable) es casi universal en la categoria, se normaliza pero no participa en la igualdad por baja capacidad discriminante."
    },
    {
      "name": "forma",
      "role": "descriptive",
      "domain": [
        "recta",
        "anatomica",
        "en_t",
        "en_l",
        "en_h",
        "gancho"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\ben h\\b|placas? en h",
          "value": "en_h"
        },
        {
          "kind": "keyword",
          "pattern": "\\ben t\\b",
          "value": "en_t"
        },
        {
          "kind": "keyword",
          "pattern": "\\ben l\\b",
          "value": "en_l"
        },
        {
          "kind": "keyword",
          "pattern": "gancho|hook",
          "value": "gancho"
        },
        {
          "kind": "keyword",
          "pattern": "recta",
          "value": "recta"
        },
        {
          "kind": "keyword",
          "pattern": "anatomic",
          "value": "anatomica"
        }
      ],
      "curation_notes": "Descriptive: la geometria/forma (recta, anatomica, en t/l/h, gancho) se normaliza como informacion util pero no define identidad por ser secundaria al segmento y calibre."
    }
  ]
}