      "curation_notes": "Identity: el hueso/segmento esqueletico fija la identidad de la placa anatomica; dominio cerrado con los huesos del pie y extremidad inferior observados."
    },
    {
      "name": "segmento",
      "role": "identity",
      "domain": [
        "proximal",
        "distal",
        "medial",
        "lateral",
        "anterolateral",
        "anteromedial",
        "posterolateral",
        "posteromedial"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\banterolateral\\b",
          "value": "anterolateral"
        },
        {
          "kind": "keyword",
          "pattern": "\\banteromedial\\b",
          "value": "anteromedial"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:posterolateral|posterolaterales|posterior\\s+lateral)\\b",
          "value": "posterolateral"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:posteromedial|posterior\\s+medial)\\b",
          "value": "posteromedial"
        },
        {
          "kind": "keyword",
          "pattern": "\\bproximal\\b",
          "value": "proximal"
        },
        {
          "kind": "keyword",
