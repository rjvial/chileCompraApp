      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\blisfranc\\b",
          "value": "lisfranc"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmaleolo\\b",
          "value": "maleolo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bnavicular\\b",
