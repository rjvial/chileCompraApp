{
  "category_id": "circuitos_ventilador_mecanico",
  "name": "Circuitos y piezas del circuito respiratorio de ventilador mecánico",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 pieza/circuito)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo_pieza': 0.78, 'poblacion': 0.38, 'talla': 0.26, 'diametro': 0.06, 'numero_ramas': 0.04, 'material': 0.02}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo_pieza",
      "role": "identity",
      "domain": [
        "circuito_ventilatorio",
        "corrugado",
        "valvula_exhalatoria",
        "sensor_flujo",
        "sensor_oxigeno",
        "sensor_co2",
        "membrana",
        "canula_binasal",
        "mascara_nasal",
        "gorro",
        "tubo_nasal",
        "pulmon_prueba",
        "trampa_agua",
        "filtro",
        "porta_filtro",
        "frasco_exhalacion",
        "conector",
        "adaptador",
        "yankauer"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "yankauer",
          "value": "yankauer"
        },
        {
          "kind": "keyword",
          "pattern": "binasal",
          "value": "canula_binasal"
        },
        {
          "kind": "keyword",
          "pattern": "\\bco\\s*2\\b",
          "value": "sensor_co2"
        },
        {
          "kind": "keyword",
          "pattern": "sensor\\s+(?:de\\s+)?oxigeno|sensor\\s+oxigeno",
          "value": "sensor_oxigeno"
        },
        {
          "kind": "keyword",
          "pattern": "sensor(?:es)?\\s+(?:de\\s+)?flujo|alambre\\s+caliente",
          "value": "sensor_flujo"
        },
        {
          "kind": "keyword",
          "pattern": "valvula\\s+exhalat|conjunto\\s+(?:completo\\s+)?exhalat",
          "value": "valvula_exhalatoria"
        },
        {
          "kind": "keyword",
          "pattern": "membrana",
          "value": "membrana"
        },
        {
          "kind": "keyword",
          "pattern": "mascara",
          "value": "mascara_nasal"
        },
        {
          "kind": "keyword",
          "pattern": "gorro",
          "value": "gorro"
        },
        {
          "kind": "keyword",
          "pattern": "pulmon",
          "value": "pulmon_prueba"
        },
        {
          "kind": "keyword",
          "pattern": "tubo\\s+nasal",
          "value": "tubo_nasal"
        },
        {
          "kind": "keyword",
          "pattern": "trampa\\s+de\\s+agua",
          "value": "trampa_agua"
        },
        {
          "kind": "keyword",
          "pattern": "porta\\s+filtro",
          "value": "porta_filtro"
        },
        {
          "kind": "keyword",
          "pattern": "frasco",
          "value": "frasco_exhalacion"
        },
        {
          "kind": "keyword",
          "pattern": "corrugado",
          "value": "corrugado"
        },
        {
          "kind": "keyword",
          "pattern": "circuito",
          "value": "circuito_ventilatorio"
        },
        {
          "kind": "keyword",
          "pattern": "conector|codo|inhalador",
          "value": "conector"
        },
        {
          "kind": "keyword",
          "pattern": "filtro",
          "value": "filtro"
        },
        {
          "kind": "keyword",
          "pattern": "adaptador",
          "value": "adaptador"
        }
      ],
      "curation_notes": "Identidad principal: el tipo de pieza/componente del circuito fija la identidad clinica en esta categoria heterogenea. Dominio cerrado a los componentes observados; reglas ordenadas de mas especifica a mas general (porta_filtro antes que filtro; sensor_co2 antes que otros sensores; circuito antes que conector para no confundir circuitos que incluyen conector/codo)."
    },
    {
      "name": "poblacion",
      "role": "identity",
      "domain": [
        "neonatal",
        "pediatrico",
        "adulto"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "neonatal",
          "value": "neonatal"
        },
        {
          "kind": "keyword",
          "pattern": "pediatric",
          "value": "pediatrico"
        },
        {
          "kind": "keyword",
          "pattern": "adulto",
          "value": "adulto"
        }
      ],
      "curation_notes": "Identity: el rango etario del paciente discrimina piezas compatibles (circuito/canula neonatal vn500 vs adulto). Dominio clinico estandar cerrado."
    },
    {
      "name": "talla",
      "role": "identity",
      "domain": [
        "talla_xs",
        "talla_s",
        "talla_m",
        "talla_l",
        "talla_xl"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\btalla\\s+(xs|xl|s|m|l)\\b",
          "template": "talla_{1}"
        },
        {
          "kind": "keyword",
          "pattern": "\\bn\\s*3\\b",
          "value": "talla_xs"
        },
        {
          "kind": "keyword",
          "pattern": "\\bn\\s*4\\b",
          "value": "talla_s"
        },
        {
          "kind": "keyword",
          "pattern": "\\bn\\s*5\\b",
          "value": "talla_m"
        },
        {
          "kind": "keyword",
          "pattern": "\\bn\\s*6\\b",
          "value": "talla_l"
        }
      ],
      "curation_notes": "Identity: la talla discrimina canulas binasales, gorros y mascaras neonatales. Regex sobre 'talla x' canonico; reglas keyword n3-n6 mapean la numeracion binasal a la talla equivalente observada (n3=xs, n4=s, n5=m, n6=l)."
    },
    {
      "name": "diametro",
      "role": "identity",
      "domain": [
        "15mm",
        "22mm"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(15|22)\\s*mm\\b",
          "template": "{1}mm"
        }
      ],
      "curation_notes": "Identity: el diametro de conexion/corrugado (15 mm neonatal-pediatrico, 22 mm adulto) define compatibilidad. Dominio cerrado a los diametros estandar observados.",
      "unit": "mm"
    },
    {
      "name": "numero_ramas",
      "role": "identity",
      "domain": [
        "1_rama",
        "2_ramas"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "doble\\s+rama|dos\\s+ramas?",
          "value": "2_ramas"
        },
        {
          "kind": "keyword",
          "pattern": "una\\s+rama|simple\\s+rama|monorrama",
          "value": "1_rama"
        }
      ],
      "curation_notes": "Identity: el numero de ramas (una rama vs doble rama) es un rasgo constructivo que distingue circuitos no intercambiables."
    },
    {
      "name": "material",
      "role": "descriptive",
      "domain": [
        "pvc",
        "silicona",
        "latex",
        "libre_latex"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "libre\\s+de\\s+latex|sin\\s+latex",
          "value": "libre_latex"
        },
        {
          "kind": "keyword",
          "pattern": "pvc",
          "value": "pvc"
        },
        {
          "kind": "keyword",
          "pattern": "silicona|silicone",
          "value": "silicona"
        },
        {
          "kind": "keyword",
          "pattern": "latex",
          "value": "latex"
        }
      ],
      "curation_notes": "Descriptive: el material se normaliza informativamente pero no participa en la igualdad; libre_latex antes que latex para no confundir 'libre de latex'."
    }
  ]
}