  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "muestras",
        "ampollas",
        "trauma",
        "emergencia",
        "primeros_auxilios",
        "botiquin",
        "porta_balones",
        "via_venosa",
        "paramedico",
        "podologia",
        "transporte_insumos",
        "transporte_equipo"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bmuestras?\\b",
          "value": "muestras"
        },
        {
          "kind": "keyword",
          "pattern": "\\bampollas?\\b|\\bampulario\\b",
          "value": "ampollas"
        },
        {
          "kind": "keyword",
          "pattern": "\\bvia venosa\\b",
          "value": "via_venosa"
        },
        {
          "kind": "keyword",
          "pattern": "\\bporta\\s*balones?\\b|\\bportabalones\\b",
          "value": "porta_balones"
        },
        {
          "kind": "keyword",
          "pattern": "\\bprimeros auxilios\\b",
          "value": "primeros_auxilios"
        },
        {
          "kind": "keyword",
          "pattern": "\\btrauma\\b",
          "value": "trauma"
        },
        {
          "kind": "keyword",
          "pattern": "\\bparamedicos?\\b",
          "value": "paramedico"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpodologia\\b",
          "value": "podologia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbotiquin\\b",
          "value": "botiquin"
        },
        {
          "kind": "keyword",
          "pattern": "\\bemergencias?\\b",
          "value": "emergencia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bporta equipo\\b|\\bgrabadora\\b|\\btelescopio\\b|\\bnotebooks?\\b|\\bequipo\\b",
          "value": "transporte_equipo"
        },
        {
          "kind": "keyword",
          "pattern": "\\binsumos?\\b",
          "value": "transporte_insumos"
        }
      ],
      "curation_notes": "Identity: el proposito/destino del bolso es el principal discriminante de producto (un bolso de muestras no es un porta balones ni un botiquin). Dominio cerrado sobre usos observados; reglas de mas especifica a mas general, con transporte_insumos como ultimo recurso."
    },
    {
      "name": "talla",
      "role": "identity",
      "domain": [
        "talla_s",
        "talla_m",
        "talla_l",
        "talla_xl"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\btalla x l\\b|\\bxl\\b",
          "value": "talla_xl"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla l\\b",
          "value": "talla_l"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla m\\b",
          "value": "talla_m"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla s\\b",
          "value": "talla_s"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpequenos?\\b|\\bchicos?\\b|\\bcompactos?\\b",
          "value": "talla_s"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmedianos?\\b",
          "value": "talla_m"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgrandes?\\b",
          "value": "talla_l"
        }
      ],
      "curation_notes": "Identity: la talla (s/m/l/xl) distingue variantes del mismo tipo de bolso. Dominio estandar de tallas; se mapean tanto la talla explicita como los terminos de tamano (pequeno/mediano/grande), priorizando xl y la talla declarada sobre los sinonimos."
    },
    {
      "name": "isotermico",
      "role": "identity",
      "domain": [
        "isotermico"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bisotermicos?\\b",
          "value": "isotermico"
        }
      ],
      "curation_notes": "Identity: la condicion isotermica define un producto distinto (cadena de frio para muestras/ampollas) frente al bolso comun. Dominio cerrado de un solo valor; ausencia = bolso no isotermico."
    },
    {
      "name": "color",
