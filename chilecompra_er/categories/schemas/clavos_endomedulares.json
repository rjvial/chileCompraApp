{
  "category_id": "clavos_endomedulares",
  "name": "Clavos endomedulares (traumatologia)",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 clavo)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'anatomia': 0.56, 'tipo': 0.22, 'diametro': 0.08, 'longitud': 0.26, 'material': 0.16, 'via': 0.08}, illegal extractions 2."
  ],
  "attribute_defs": [
    {
      "name": "anatomia",
      "role": "identity",
      "domain": [
        "femur",
        "tibia",
        "fibula",
        "tobillo"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "tibio\\s*talo\\s*calcaneo|artrodesis\\s+de\\s+tobillo|\\btobillo\\b",
          "value": "tobillo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfemur\\b|\\bfemoral\\b|\\bcadera\\b",
          "value": "femur"
        },
        {
          "kind": "keyword",
          "pattern": "\\btibia\\b",
          "value": "tibia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfibula\\b|\\bperone\\b",
          "value": "fibula"
        }
      ],
      "curation_notes": "identity: el segmento oseo (femur/tibia/fibula/tobillo) define un producto distinto; cierre por anatomias observadas en el corpus."
    },
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "cefalomedular",
        "elastico",
        "telescopico",
        "convencional",
        "artrodesis"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "cefalo\\s*medular|\\btfn\\b|gamma",
          "value": "cefalomedular"
        },
        {
          "kind": "keyword",
          "pattern": "telescopico|fassier\\s*duval|\\bjcd\\b",
          "value": "telescopico"
        },
        {
          "kind": "keyword",
          "pattern": "\\belastico\\b",
          "value": "elastico"
        },
        {
          "kind": "keyword",
          "pattern": "\\bartrodesis\\b",
          "value": "artrodesis"
        },
        {
          "kind": "keyword",
          "pattern": "\\bconvencional\\b",
          "value": "convencional"
        }
      ],
      "curation_notes": "identity: el diseno del clavo (cefalomedular/elastico/telescopico/convencional/artrodesis) discrimina familias no intercambiables."
    },
    {
      "name": "diametro",
      "role": "identity",
      "domain": [
        "3.6mm",
        "3.8mm",
        "5.0mm",
        "5.6mm",
        "7mm",
        "8mm",
        "9mm",
        "10mm",
        "11mm",
        "12mm",
        "13mm",
        "14mm",
        "15.5mm"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\bdiametro\\s+de\\s+(\\d{1,2}(?:\\.\\d)?)\\b",
          "template": "{1}mm"
        },
        {
          "kind": "regex",
          "pattern": "\\bdiametro[s]?\\s+(\\d{1,2}(?:\\.\\d)?)\\b",
          "template": "{1}mm"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2}(?:\\.\\d)?)\\s*mm\\s+(?:tipo|diametro)\\b",
          "template": "{1}mm"
        },
        {
          "kind": "regex",
          "pattern": "\\bclavo\\s+(?:telescopico\\s+)?(\\d(?:\\.\\d)?)\\s*mm\\b",
          "template": "{1}mm"
        }
      ],
      "curation_notes": "identity: el diametro del clavo (mm) fija calibre; dominio cerrado a medidas estandar observadas en traumatologia.",
      "unit": "mm"
    },
    {
      "name": "longitud",
      "role": "identity",
      "domain": [
        "100mm",
        "110mm",
        "120mm",
        "130mm",
        "140mm",
        "150mm",
        "160mm",
        "170mm",
        "180mm",
        "190mm",
        "200mm",
        "220mm",
        "240mm",
        "255mm",
        "260mm",
        "280mm",
        "300mm",
        "320mm",
        "340mm",
        "360mm",
        "380mm",
        "400mm",
        "420mm"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\blongitud(?:es)?\\s+(?:hasta\\s+)?(\\d{3})\\b",
          "template": "{1}mm"
        },
        {
          "kind": "regex",
          "pattern": "\\blargo[s]?\\s+(?:desde\\s+)?(\\d{3})\\b",
          "template": "{1}mm"
        },
        {
          "kind": "regex",
          "pattern": "\\bclavo\\s+\\d{1,2}\\s*x\\s*(\\d{3})\\b",
          "template": "{1}mm"
        },
        {
          "kind": "regex",
          "pattern": "\\bx\\s+(\\d{3})\\s*mm\\b",
          "template": "{1}mm"
        }
      ],
      "curation_notes": "identity: la longitud del clavo (mm) define la talla anatomica; dominio cerrado a largos estandar.",
      "unit": "mm"
    },
    {
      "name": "material",
      "role": "descriptive",
      "domain": [
        "titanio",
        "acero_inoxidable"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\btitanio\\b",
          "value": "titanio"
        },
        {
          "kind": "keyword",
          "pattern": "acero\\s+inoxidable|\\binoxidable\\b|\\bacero\\b",
          "value": "acero_inoxidable"
        }
      ],
      "curation_notes": "descriptive: muchas bases especifican 'acero inoxidable o titanio' como intercambiables, por lo que el material no discrimina identidad."
    },
    {
      "name": "via",
      "role": "descriptive",
      "domain": [
        "anterogrado",
        "retrogrado"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "retrogrado",
          "value": "retrogrado"
        },
        {
          "kind": "keyword",
          "pattern": "anterogrado",
          "value": "anterogrado"
        }
      ],
      "curation_notes": "descriptive: la via de insercion se normaliza, pero los sets suelen permitir anterogrado y retrogrado, asi que no fija identidad."
    }
  ]
}