        },
        {
          "kind": "keyword",
          "pattern": "\\bceleste\\b",
          "value": "celeste"
        },
        {
          "kind": "keyword",
          "pattern": "\\bamarill[oa]s?\\b",
          "value": "amarillo"
        }
      ],
      "curation_notes": "Identity: el color discrimina articulos equivalentes (camisa verde vs camisa blanca) y suele asociarse al uso (verde quirurgico vs blanco de cama); dominio cerrado con los colores observados."
    },
    {
      "name": "talla",
      "role": "identity",
      "domain": [
        "talla_xs",
        "talla_s",
        "talla_m",
        "talla_l",
        "talla_xl"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\btalla\\s+xs\\b",
          "value": "talla_xs"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla\\s+xl\\b",
          "value": "talla_xl"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla\\s+l\\b",
          "value": "talla_l"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla\\s+m\\b",
          "value": "talla_m"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla\\s+s\\b",
          "value": "talla_s"
        }
      ],
      "curation_notes": "Identity: la talla distingue variantes de la misma prenda (blusa/delantal s, l, xl); dominio cerrado de tallas estandar por letra. Las tallas numericas/pediatricas (talla 60, talla n 12) no se canonizan en este borrador y quedan sin captura."
    }
  ]
