  "attribute_defs": [
    {
      "name": "tipo_prenda",
      "role": "identity",
      "domain": [
        "sabana",
        "funda_almohada",
        "almohada",
        "camisa",
        "blusa",
        "pantalon",
        "delantal",
        "bata",
        "bota",
        "pano_clinico",
        "gorro",
        "frazada",
        "cobertor",
        "venda",
        "bikini",
        "loneta",
        "bolsa_ropa_sucia"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bfundas?\\s+(?:de\\s+)?almohada\\b",
          "value": "funda_almohada"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:bolsa|saco)\\b.*ropa\\s+sucia",
          "value": "bolsa_ropa_sucia"
        },
        {
          "kind": "keyword",
          "pattern": "\\balmohadas?\\b",
          "value": "almohada"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsabanas?\\b",
          "value": "sabana"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcamisas?\\b",
          "value": "camisa"
        },
        {
          "kind": "keyword",
          "pattern": "\\bblusas?\\b",
          "value": "blusa"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpantalon(?:es)?\\b",
          "value": "pantalon"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdelantal(?:es)?\\b",
          "value": "delantal"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbatas?\\b",
          "value": "bata"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbotas?\\b",
          "value": "bota"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpanos?\\b",
          "value": "pano_clinico"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgorros?\\b",
          "value": "gorro"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfrazadas?\\b",
          "value": "frazada"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcobertor(?:es)?\\b",
          "value": "cobertor"
        },
        {
          "kind": "keyword",
          "pattern": "\\bvendas?\\b",
          "value": "venda"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbikinis?\\b",
          "value": "bikini"
        },
        {
          "kind": "keyword",
          "pattern": "\\blonetas?\\b",
          "value": "loneta"
        }
      ],
      "curation_notes": "Identity: el tipo de prenda/articulo es el eje principal que distingue productos de la categoria; dominio cerrado con los articulos observados. Reglas keyword ordenadas de especifico a general (funda_almohada y bolsa_ropa_sucia antes que almohada/articulos genericos)."
    },
    {
      "name": "material",
      "role": "identity",
      "domain": [
        "crea",
        "algodon",
        "poliester",
        "trevira",
        "moleton",
        "damasco",
        "policron"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\btrevira\\b",
          "value": "trevira"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmoleton\\b",
          "value": "moleton"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpolicron\\b",
          "value": "policron"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdamasco\\b",
          "value": "damasco"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpoliester\\b",
          "value": "poliester"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcrea\\b",
          "value": "crea"
        },
        {
          "kind": "keyword",
          "pattern": "\\balgodon\\b",
          "value": "algodon"
        }
      ],
      "curation_notes": "Identity: la tela define identidad y uso clinico (crea/algodon vs sinteticos); dominio cerrado con los materiales nombrados. Sinteticos y telas especificas (trevira, moleton, damasco, policron) priorizados antes de crea/algodon, que son los mas frecuentes y genericos."
    },
    {
      "name": "color",
      "role": "identity",
      "domain": [
        "verde",
        "blanco",
        "beige",
        "cafe",
        "celeste",
        "amarillo"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bverde\\b",
          "value": "verde"
        },
        {
          "kind": "keyword",
          "pattern": "\\bblanc[oa]s?\\b",
          "value": "blanco"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbeige\\b",
          "value": "beige"
        },
        {
          "kind": "keyword",
