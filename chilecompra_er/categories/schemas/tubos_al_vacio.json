{
  "category_id": "tubos_al_vacio",
  "name": "Tubos al vacío para laboratorio",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 tubo)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo_producto': 1.0, 'capacidad': 0.66, 'color_tapa': 0.62, 'aditivo': 0.54, 'calibre': 0.1, 'esteril': 0.06}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo_producto",
      "role": "identity",
      "domain": [
        "tubo",
        "aguja_multiple",
        "mariposa",
        "set_colector",
        "holder",
        "adaptador_luer",
        "torniquete",
        "frasco_orina",
        "tubo_orina",
        "frasco_heces",
        "jeringa",
        "torula",
        "caja_transporte",
        "cinta_quirurgica",
        "parche",
        "sachet_alcohol",
        "identificadores"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\baguja multiple\\b",
          "value": "aguja_multiple"
        },
        {
          "kind": "keyword",
          "pattern": "\\badaptador luer\\b",
          "value": "adaptador_luer"
        },
        {
          "kind": "keyword",
          "pattern": "\\bset colector\\b",
          "value": "set_colector"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmariposa\\b",
          "value": "mariposa"
        },
        {
          "kind": "keyword",
          "pattern": "\\bholder\\b",
          "value": "holder"
        },
        {
          "kind": "keyword",
          "pattern": "\\btorniquete\\b",
          "value": "torniquete"
        },
        {
          "kind": "keyword",
          "pattern": "\\btubo para extraccion de orina\\b",
          "value": "tubo_orina"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfrascos? de orina\\b",
          "value": "frasco_orina"
        },
        {
          "kind": "keyword",
          "pattern": "\\bheces\\b",
          "value": "frasco_heces"
        },
        {
          "kind": "keyword",
          "pattern": "\\bjeringa\\b",
          "value": "jeringa"
        },
        {
          "kind": "keyword",
          "pattern": "\\btorula\\b",
          "value": "torula"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcaja de transporte\\b",
          "value": "caja_transporte"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcinta quirurgica\\b",
          "value": "cinta_quirurgica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bparche\\b",
          "value": "parche"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsachet\\b",
          "value": "sachet_alcohol"
        },
        {
          "kind": "keyword",
          "pattern": "\\bidentificadores\\b",
          "value": "identificadores"
        },
        {
          "kind": "keyword",
          "pattern": "\\btubo\\b",
          "value": "tubo"
        }
      ],
      "curation_notes": "Identidad gruesa que separa familias de productos heterogeneos (tubo de sangre vs aguja, holder, torniquete, frasco, etc.); reglas ordenadas para que 'tubo' generico quede al final y los frascos/tubos de orina se capturen antes."
    },
    {
      "name": "capacidad",
      "role": "identity",
      "domain": [
        "0.5ml",
        "1ml",
        "2ml",
        "3ml",
        "3.5ml",
        "4ml",
        "5ml",
        "6ml",
        "8ml",
        "9ml",
        "9.5ml",
        "60ml",
        "100ml"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,3}(?:\\.\\d)?)\\s*ml\\b",
          "template": "{1}ml"
        }
      ],
      "curation_notes": "Volumen nominal en ml: discrimina SKUs dentro de un mismo color/aditivo (2/3/4/6/9 ml) y cubre frascos de orina/heces (60/100 ml); identidad clara.",
      "unit": "ml"
    },
    {
      "name": "color_tapa",
      "role": "identity",
      "domain": [
        "verde",
        "lavanda",
        "gris",
        "roja",
        "celeste",
        "blanca",
        "lila",
        "amarilla"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\btapa verde\\b",
          "value": "verde"
        },
        {
          "kind": "keyword",
          "pattern": "\\btapa lavanda\\b",
          "value": "lavanda"
        },
        {
          "kind": "keyword",
          "pattern": "\\btapa gris\\b",
          "value": "gris"
        },
        {
          "kind": "keyword",
          "pattern": "\\btapa roja\\b",
          "value": "roja"
        },
        {
          "kind": "keyword",
          "pattern": "\\btapa celeste\\b",
          "value": "celeste"
        },
        {
          "kind": "keyword",
          "pattern": "\\btapa blanca\\b",
          "value": "blanca"
        },
        {
          "kind": "keyword",
          "pattern": "\\btapa lila\\b",
          "value": "lila"
        },
        {
          "kind": "keyword",
          "pattern": "\\btapa amarilla\\b",
          "value": "amarilla"
        }
      ],
      "curation_notes": "Color de tapa codifica por convencion el sistema de aditivo del tubo; identidad fuerte y observable directamente en la descripcion."
    },
    {
      "name": "aditivo",
      "role": "identity",
      "domain": [
        "heparina_litio",
        "heparina_sodio",
        "edta_k3",
        "fluoruro_oxalato",
        "activador_coagulo",
        "gel_activador_coagulo",
        "citrato_sodio",
        "sin_aditivo"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bgel separador\\b",
          "value": "gel_activador_coagulo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bactivador de coagulo\\b",
          "value": "activador_coagulo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhep(?:arina)? de litio\\b",
          "value": "heparina_litio"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhep(?:arina)? de sodio\\b",
          "value": "heparina_sodio"
        },
        {
          "kind": "keyword",
          "pattern": "\\bedta\\s*k\\s*3\\b",
          "value": "edta_k3"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfluoruro oxalato\\b",
          "value": "fluoruro_oxalato"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcitrato de sodio\\b",
          "value": "citrato_sodio"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsin aditivo\\b",
          "value": "sin_aditivo"
        }
      ],
      "curation_notes": "Aditivo/anticoagulante define el uso clinico del tubo y es identidad; 'gel separador y activador' se captura antes que 'activador' solo para no colapsar ambos productos."
    },
    {
      "name": "calibre",
      "role": "identity",
      "domain": [
        "19g",
        "21g",
        "22g",
        "23g"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{2})\\s*g\\b",
          "template": "{1}g"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{2})\\s*g\\s*x",
          "template": "{1}g"
        }
      ],
      "curation_notes": "Calibre en gauge de agujas multiples/mariposas/set colector; identidad para esos productos (21/22/23/19 g), nulo en el resto.",
      "unit": "g"
    },
    {
      "name": "esteril",
      "role": "descriptive",
      "domain": [
        "esteril"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\besteril\\b",
          "value": "esteril"
        }
      ],
      "curation_notes": "Se normaliza la mencion de esterilidad (tubos de orina, torula) como atributo descriptivo; no participa en la igualdad para no fragmentar SKUs que simplemente omiten el termino."
    }
  ]
}