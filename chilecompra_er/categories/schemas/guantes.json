{
  "category_id": "guantes",
  "name": "Guantes (procedimiento/quirurgicos/aseo)",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 guante)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 0.74, 'material': 0.54, 'talla': 0.84, 'esteril': 0.14, 'polvo': 0.12}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "procedimiento",
        "quirurgico",
        "domestico",
        "industrial",
        "proteccion"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bquirurgico",
          "value": "quirurgico"
        },
        {
          "kind": "keyword",
          "pattern": "\\bprocedimiento",
          "value": "procedimiento"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:soldar|soldador|soldadura|albanil|descarne|multiproposito)\\b",
          "value": "industrial"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:plomado|plomo|radiologica)\\b",
          "value": "proteccion"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:aseo|domestico|domesticos|multiuso|afelpado|afelpados|gamuzado|gamuzada)\\b",
          "value": "domestico"
        }
      ],
      "curation_notes": "Identity: el uso/tipo de guante (procedimiento vs quirurgico vs domestico/industrial/proteccion) discrimina productos no intercambiables; dominio cerrado segun usos observados."
    },
    {
      "name": "material",
      "role": "identity",
      "domain": [
        "nitrilo",
        "vinilo",
        "latex",
        "cuero",
        "polar",
        "goma"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bnitrilo\\b",
          "value": "nitrilo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bvinilo\\b",
          "value": "vinilo"
        },
        {
          "kind": "keyword",
          "pattern": "\\blatex\\b",
          "value": "latex"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:cuero|descarne)\\b",
          "value": "cuero"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpolar\\b",
          "value": "polar"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgoma\\b",
          "value": "goma"
        }
      ],
      "curation_notes": "Identity: el material define la identidad del guante (nitrilo, latex, vinilo, etc. no son equivalentes); dominio cerrado por materiales observados."
    },
    {
      "name": "talla",
      "role": "identity",
      "domain": [
        "talla_xs",
        "talla_s",
        "talla_m",
        "talla_l",
        "talla_xl",
        "6",
        "6_5",
        "7",
        "7_5",
        "8"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\bn\\s+(\\d)\\b",
          "template": "{1}"
        },
        {
          "kind": "regex",
          "pattern": "\\btalla\\s+(xs|xl|s|m|l)\\b",
          "template": "talla_{1}"
        },
        {
          "kind": "keyword",
          "pattern": "\\bextra\\s*small\\b",
          "value": "talla_xs"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsmall\\b",
          "value": "talla_s"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmedium\\b",
          "value": "talla_m"
        },
        {
          "kind": "keyword",
          "pattern": "\\blarge\\b",
          "value": "talla_l"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:mediano|mediana|medianos|medianas)\\b",
          "value": "talla_m"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:pequeno|pequena|pequenos)\\b",
          "value": "talla_s"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(?:grande|grandes)\\b",
          "value": "talla_l"
        },
        {
          "kind": "keyword",
          "pattern": "\\bxs\\b",
          "value": "talla_xs"
        },
        {
          "kind": "keyword",
          "pattern": "\\bxl\\b",
          "value": "talla_xl"
        },
        {
          "kind": "keyword",
          "pattern": "\\bs\\b",
          "value": "talla_s"
        },
        {
          "kind": "keyword",
          "pattern": "\\bm\\b",
          "value": "talla_m"
        },
        {
          "kind": "keyword",
          "pattern": "\\bl\\b",
          "value": "talla_l"
        }
      ],
      "curation_notes": "Identity: la talla discrimina unidades vendidas; incluye sistema de letras (xs-xl) y numeracion quirurgica (6-8); reglas de letra suelta al final por ser mas ambiguas."
    },
    {
      "name": "esteril",
      "role": "identity",
      "domain": [
        "esteril",
        "no_esteril"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bno\\s+esteril",
          "value": "no_esteril"
        },
        {
          "kind": "keyword",
          "pattern": "\\besteril",
          "value": "esteril"
        }
      ],
      "curation_notes": "Identity: esteril vs no esteril es una distincion funcional/regulatoria que separa productos no intercambiables en uso clinico."
    },
    {
      "name": "polvo",
      "role": "descriptive",
      "domain": [
        "con_polvo",
        "sin_polvo"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bsin\\s+polvo\\b",
          "value": "sin_polvo"
        },
        {
          "kind": "keyword",
          "pattern": "\\blibre[s]?\\s+de\\s+polvo\\b",
          "value": "sin_polvo"
        },
        {
          "kind": "keyword",
          "pattern": "\\blibre[s]?\\s+de\\s+talco\\b",
          "value": "sin_polvo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsin\\s+(?:talco|talco)\\b",
          "value": "sin_polvo"
        },
        {
          "kind": "keyword",
          "pattern": "\\ben\\s+polvo\\b",
          "value": "con_polvo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcon\\s+polvo\\b",
          "value": "con_polvo"
        }
      ],
      "curation_notes": "Descriptive: se normaliza la presencia/ausencia de polvo o talco pero no participa en la igualdad para mantener el conjunto de identidad acotado."
    }
  ]
}