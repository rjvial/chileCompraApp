    {
      "name": "calibre",
      "role": "identity",
      "domain": [
        "8g",
        "12g",
        "16g",
        "18g",
        "6fr",
        "6.3fr",
        "8fr",
        "8.5fr",
        "10fr",
        "10.2fr",
        "12fr",
        "14fr",
        "16fr",
        "18fr",
        "20fr",
        "22fr",
        "24fr"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2}(?:\\.\\d)?)\\s*fr\\b",
          "template": "{1}fr"
        },
        {
          "kind": "regex",
          "pattern": "\\bg\\s*(\\d{1,2})\\b",
          "template": "{1}g"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2}(?:\\.\\d)?)\\s*f\\b",
          "template": "{1}fr"
        }
      ],
      "curation_notes": "Identity: el calibre fija el tamano del drenaje/trocar; el valor canonico lleva sufijo de escala porque conviven French (fr/f) y gauge (g, en trocares); regla fr y f mapean a French, g a gauge, fr primero por ser mas especifica."
    },
