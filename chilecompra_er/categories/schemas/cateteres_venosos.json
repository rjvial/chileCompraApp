  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "branula",
        "central_transitorio",
        "tunelizado",
        "picc",
        "hemodialisis",
        "central"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bhemodialisis\\b",
          "value": "hemodialisis"
        },
        {
          "kind": "keyword",
          "pattern": "\\btunelizado\\b",
          "value": "tunelizado"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpicc\\b",
          "value": "picc"
        },
        {
          "kind": "keyword",
          "pattern": "\\btransitorio\\b",
          "value": "central_transitorio"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbranula\\b|\\bcanula iv\\b|\\bteflon\\b",
          "value": "branula"
        },
        {
          "kind": "keyword",
          "pattern": "venoso central",
          "value": "central"
        }
      ],
      "curation_notes": "Identidad: distingue clases clinicas reales (periferica/branula vs central transitorio vs tunelizado vs picc vs hemodialisis); hemodialisis precede a transitorio por ser subtipo mas especifico; 'central' generico como ultimo recurso."
    },
    {
      "name": "calibre",
      "role": "identity",
      "domain": [
        "14g",
        "16g",
        "18g",
        "20g",
        "22g",
        "24g",
        "26g",
        "3fr",
        "3.5fr",
        "4fr",
        "4.5fr",
        "5fr",
        "5.5fr",
        "6fr",
        "7fr",
        "8fr",
        "8.5fr",
        "9fr",
        "11fr",
        "12fr"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2}\\.\\d)\\s*fr\\b",
          "template": "{1}fr"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})(?:\\.0)?\\s*fr\\b",
          "template": "{1}fr"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*ga?\\b",
          "template": "{1}g"
        },
        {
          "kind": "regex",
          "pattern": "\\bn\\s*(\\d{2})\\b",
          "template": "{1}g"
        },
        {
          "kind": "keyword",
          "pattern": "\\bamarill",
          "value": "24g"
        },
        {
          "kind": "keyword",
          "pattern": "\\bceleste",
          "value": "22g"
        },
        {
          "kind": "keyword",
          "pattern": "\\brosad",
          "value": "20g"
        },
        {
          "kind": "keyword",
          "pattern": "\\bverde",
          "value": "18g"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgris",
          "value": "16g"
        },
        {
          "kind": "keyword",
          "pattern": "\\bnaranj",
          "value": "14g"
        }
      ],
      "curation_notes": "Identidad nuclear: calibre en french (fr, centrales) o gauge (g/ga, branulas); reglas fr decimal/entero antes que gauge; codigo de color estandar IV (amarillo=24g, celeste=22g, etc.) y 'n NN' como respaldo cuando falta la unidad."
    },
    {
      "name": "numero_lumenes",
      "role": "identity",
      "domain": [
        "1_lumen",
        "2_lumen",
        "3_lumen",
        "4_lumen"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bmonolumen\\b",
          "value": "1_lumen"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d)\\s*lumen",
          "template": "{1}_lumen"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d)\\s*vias?\\b",
          "template": "{1}_lumen"
        }
      ],
      "curation_notes": "Identidad: el numero de lumenes/vias discrimina productos centrales (monolumen, 2, 3 lumen, 3 vias); 'monolumen' mapea a 1; las branulas sin mencion quedan sin valor (lumen unico implicito)."
    },
    {
      "name": "longitud",
      "role": "identity",
      "domain": [
        "5cm",
        "8cm",
        "10cm",
        "12.5cm",
        "13cm",
        "15cm",
