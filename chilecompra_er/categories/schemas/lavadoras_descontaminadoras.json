        "madensa",
        "choyang",
        "samsung",
        "sedile",
        "oppici"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bsteelco\\b",
          "value": "steelco"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsmeg\\b",
          "value": "smeg"
        },
        {
          "kind": "keyword",
          "pattern": "\\blabconco\\b",
          "value": "labconco"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmadensa\\b",
          "value": "madensa"
        },
        {
          "kind": "keyword",
          "pattern": "\\bchoyang\\b",
          "value": "choyang"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsamsung\\b",
          "value": "samsung"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsedile\\b",
          "value": "sedile"
        },
        {
          "kind": "keyword",
          "pattern": "\\boppici\\b",
          "value": "oppici"
        }
      ],
      "curation_notes": "Descriptive: se normaliza la marca para enriquecer pero no participa en la igualdad; dominio cerrado con marcas de equipos observadas."
    },
    {
      "name": "potencia",
      "role": "descriptive",
      "domain": [
        "1400w"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{3,4})\\s*w\\b",
          "template": "{1}w"
        }
      ],
      "curation_notes": "Descriptive: potencia electrica en watts (p.ej. hidrolavadora 1400 w) se normaliza pero no fija identidad por aparecer de forma marginal.",
      "unit": "w"
    }
  ]
