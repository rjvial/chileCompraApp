{
  "category_id": "lavadoras_descontaminadoras",
  "name": "Lavadoras ultrasónicas y descontaminadoras de instrumental",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 lavadora)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 0.86, 'capacidad_litros': 0.1, 'carga_kg': 0.06, 'marca': 0.26, 'potencia': 0.04}, illegal extractions 1."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "ultrasonica",
        "descontaminadora",
        "termodesinfectadora",
        "desinfectadora",
        "mamaderas",
        "endoscopios",
        "industrial",
        "automatica",
        "hidrolavadora"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bultrason",
          "value": "ultrasonica"
        },
        {
          "kind": "keyword",
          "pattern": "\\btermodesinfect",
          "value": "termodesinfectadora"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdescontaminadora",
          "value": "descontaminadora"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdesinsect",
          "value": "desinfectadora"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdesinfect",
          "value": "desinfectadora"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmamaderas?\\b",
          "value": "mamaderas"
        },
        {
          "kind": "keyword",
          "pattern": "\\bendoscop",
          "value": "endoscopios"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhidrolavadora",
          "value": "hidrolavadora"
        },
        {
          "kind": "keyword",
          "pattern": "\\bindustrial",
          "value": "industrial"
        },
        {
          "kind": "keyword",
          "pattern": "\\bautomatica\\b",
          "value": "automatica"
        }
      ],
      "curation_notes": "Identity: el tipo funcional distingue equipos no equivalentes (ultrasonica vs descontaminadora/termodesinfectadora vs mamaderas vs endoscopios vs industrial/ropa vs hidrolavadora); dominio cerrado segun variantes observadas, reglas ordenadas de especifica a general (termodesinfect antes que desinfect)."
    },
    {
      "name": "capacidad_litros",
      "role": "identity",
      "domain": [
        "1.5l",
        "2l",
        "3l",
        "5l",
        "6l",
        "10l",
        "14l",
        "15l",
        "18l",
        "20l",
        "25l",
        "30l"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,3}(?:\\.\\d)?)\\s*(?:lts?|litros?)\\b",
          "template": "{1}l"
        }
      ],
      "curation_notes": "Identity: la capacidad de cuba en litros discrimina modelos del mismo tipo (p.ej. ultrasonica 10 lts); dominio cerrado generoso con litrajes estandar.",
      "unit": "l"
    },
    {
      "name": "carga_kg",
      "role": "identity",
      "domain": [
        "5kg",
        "8kg",
        "10kg",
        "15kg",
        "18kg",
        "20kg",
        "25kg"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,3})\\s*(?:kg|kilos?)\\b",
          "template": "{1}kg"
        }
      ],
      "curation_notes": "Identity: la capacidad de carga en kilos distingue lavadoras industriales/de ropa (18 kg, 20 kg); dominio cerrado con cargas estandar.",
      "unit": "kg"
    },
    {
      "name": "marca",
      "role": "descriptive",
      "domain": [
