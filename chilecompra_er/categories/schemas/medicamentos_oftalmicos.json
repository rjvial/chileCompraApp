{
  "category_id": "medicamentos_oftalmicos",
  "name": "Medicamentos oftálmicos",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "envase (1 frasco)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'principio_activo': 0.98, 'concentracion': 0.56, 'forma_farmaceutica': 0.98, 'volumen': 0.46}, illegal extractions 5."
  ],
  "attribute_defs": [
    {
      "name": "principio_activo",
      "role": "identity",
      "domain": [
        "aciclovir",
        "cloramfenicol",
        "pilocarpina",
        "latanoprost",
        "atropina",
        "brimonidina",
        "ciclopentolato",
        "hialuronato_sodico",
        "loteprednol",
        "nepafenaco",
        "prednisolona",
        "proparacaina",
        "timolol",
        "tropicamida",
        "moxifloxacino",
        "fenilefrina",
        "gentamicina",
        "tobramicina",
        "bromofenaco",
        "dexametasona",
        "carbomer",
        "lagrimas_artificiales",
        "dorzolamida_timolol",
        "gentamicina_betametasona",
        "tobramicina_dexametasona",
        "polietilenglicol_propilenglicol",
        "dextran_hipromelosa"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "(?=.*dorzolamida)(?=.*timolol)",
          "value": "dorzolamida_timolol"
        },
        {
          "kind": "keyword",
          "pattern": "(?=.*gentamicina)(?=.*betametasona)",
          "value": "gentamicina_betametasona"
        },
        {
          "kind": "keyword",
          "pattern": "(?=.*tobramicina)(?=.*dexametasona)",
          "value": "tobramicina_dexametasona"
        },
        {
          "kind": "keyword",
          "pattern": "(?=.*polietilenglicol)(?=.*propileng)",
          "value": "polietilenglicol_propilenglicol"
        },
        {
          "kind": "keyword",
          "pattern": "(?=.*dextran)(?=.*hipromelosa)",
          "value": "dextran_hipromelosa"
        },
        {
          "kind": "keyword",
          "pattern": "\\baciclovir\\b",
          "value": "aciclovir"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcloramfenicol\\b",
          "value": "cloramfenicol"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpilocarpina\\b",
          "value": "pilocarpina"
        },
        {
          "kind": "keyword",
          "pattern": "\\blatanoprost\\b",
          "value": "latanoprost"
        },
        {
          "kind": "keyword",
          "pattern": "\\batropina\\b",
          "value": "atropina"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbrimonidina\\b",
          "value": "brimonidina"
        },
        {
          "kind": "keyword",
          "pattern": "\\bciclopentolato\\b",
          "value": "ciclopentolato"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhialuronato\\b",
          "value": "hialuronato_sodico"
        },
        {
          "kind": "keyword",
          "pattern": "\\bloteprednol\\b",
          "value": "loteprednol"
        },
        {
          "kind": "keyword",
          "pattern": "\\bnepafenaco\\b",
          "value": "nepafenaco"
        },
        {
          "kind": "keyword",
          "pattern": "\\bprednisolona\\b",
          "value": "prednisolona"
        },
        {
          "kind": "keyword",
          "pattern": "\\bproparacaina\\b",
          "value": "proparacaina"
        },
        {
          "kind": "keyword",
          "pattern": "\\btropicamida\\b",
          "value": "tropicamida"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmoxifloxacino\\b",
          "value": "moxifloxacino"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfenilefrina\\b",
          "value": "fenilefrina"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbromofenaco\\b",
          "value": "bromofenaco"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgentamicina\\b",
          "value": "gentamicina"
        },
        {
          "kind": "keyword",
          "pattern": "\\btobramicina\\b",
          "value": "tobramicina"
        },
        {
          "kind": "keyword",
          "pattern": "\\btimolol\\b",
          "value": "timolol"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdexametasona\\b",
          "value": "dexametasona"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcarbomer\\b",
          "value": "carbomer"
        },
        {
          "kind": "keyword",
          "pattern": "lagrimas\\s+artificiales",
          "value": "lagrimas_artificiales"
        }
      ],
      "curation_notes": "Identidad central del medicamento: el principio activo (o combinacion fija) distingue productos; dominio cerrado de activos observados, combinaciones resueltas antes que los singulares."
    },
    {
      "name": "concentracion",
      "role": "identity",
      "domain": [
        "0.01%",
        "0.09%",
        "0.1%",
        "0.15%",
        "0.2%",
        "0.3%",
        "0.5%",
        "1%",
        "2%",
        "2.5%",
        "3%",
        "4%"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d+(?:\\.\\d+)?)\\s*%",
          "template": "{1}%"
        }
      ],
      "curation_notes": "La concentracion discrimina identidad entre presentaciones del mismo activo (p.ej. pilocarpina 1% vs 4%); se captura el porcentaje normalizado.",
      "unit": "%"
    },
    {
      "name": "forma_farmaceutica",
      "role": "identity",
      "domain": [
        "solucion",
        "suspension",
        "unguento",
        "gel",
        "implante"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bimplante\\b",
          "value": "implante"
        },
        {
          "kind": "keyword",
          "pattern": "ung(?:uento|to)\\b|\\bpomada\\b",
          "value": "unguento"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgel\\b",
          "value": "gel"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsuspension\\b",
          "value": "suspension"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsoluci?on\\b|\\bsol\\b|\\bgotas\\b|\\bcolirio\\b",
          "value": "solucion"
        }
      ],
      "curation_notes": "La forma farmaceutica (solucion, suspension, unguento, gel, implante) distingue identidad del producto; gotas/colirio se mapean a solucion, ungto/pomada a unguento."
    },
    {
      "name": "volumen",
      "role": "descriptive",
      "domain": [
        "2.5ml",
        "3ml",
        "5ml",
        "10ml",
        "15ml",
        "20ml",
        "100ml",
        "3.5gr",
        "10gr"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d+(?:\\.\\d+)?)\\s*ml\\b",
          "template": "{1}ml"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d+(?:\\.\\d+)?)\\s*(?:gr|g)\\b",
          "template": "{1}gr"
        }
      ],
      "curation_notes": "Volumen/contenido del envase: normaliza el tamano de presentacion pero es base de precio, no identidad; rol descriptivo.",
      "unit": "ml"
    }
  ]
}