{
  "category_id": "sensores_spo2",
  "name": "Sensores SpO2",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 sensor)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo_paciente': 0.82, 'reusabilidad': 0.14, 'fijacion': 0.6, 'tecnologia': 0.22, 'marca_monitor': 0.64}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo_paciente",
      "role": "identity",
      "domain": [
        "adulto",
        "pediatrico",
        "infantil",
        "neonatal"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bneonat(?:al|o)\\b",
          "value": "neonatal"
        },
        {
          "kind": "keyword",
          "pattern": "\\binfantil\\b",
          "value": "infantil"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpediatric[oa]\\b",
          "value": "pediatrico"
        },
        {
          "kind": "keyword",
          "pattern": "\\badult[oa]\\b",
          "value": "adulto"
        }
      ],
      "curation_notes": "identity: el tamano/poblacion del paciente (adulto/pediatrico/infantil/neonatal) discrimina productos distintos y aparece de forma sistematica; neonato se canoniza a neonatal."
    },
    {
      "name": "reusabilidad",
      "role": "identity",
      "domain": [
        "reusable",
        "desechable"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\breusable\\b",
          "value": "reusable"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdesechable\\b",
          "value": "desechable"
        }
      ],
      "curation_notes": "identity: reusable vs desechable es una distincion de producto explicita y separa SKU diferentes; ausente queda sin valor."
    },
    {
      "name": "fijacion",
      "role": "identity",
      "domain": [
        "clip",
        "wrap",
        "finger",
        "soft",
        "multisitio"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bmultisitio\\b",
          "value": "multisitio"
        },
        {
          "kind": "keyword",
          "pattern": "\\bwrap\\b",
          "value": "wrap"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfinger\\b",
          "value": "finger"
        },
        {
          "kind": "keyword",
          "pattern": "punta suave|\\bsoft\\b",
          "value": "soft"
        },
        {
          "kind": "keyword",
          "pattern": "\\bclip\\b|\\bpinza\\b",
          "value": "clip"
        }
      ],
      "curation_notes": "identity: el formato de fijacion al dedo/extremidad (clip o pinza, wrap, finger, soft, multisitio) distingue productos; pinza se canoniza a clip."
    },
    {
      "name": "tecnologia",
      "role": "identity",
      "domain": [
        "masimo",
        "nellcor"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bmas+imo\\b|\\blncs\\b",
          "value": "masimo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bnellcor\\b|\\boximax\\b",
          "value": "nellcor"
        }
      ],
      "curation_notes": "identity: la tecnologia/plataforma de oximetria (masimo lncs vs nellcor oximax) determina compatibilidad y separa productos; massimo y lncs se canonizan a masimo, oximax a nellcor."
    },
    {
      "name": "marca_monitor",
      "role": "descriptive",
      "domain": [
        "general_electric",
        "criticare",
        "spacelabs",
        "drager",
        "philips",
        "nihon_kohden",
        "mindray",
        "dixtal",
        "bionet",
        "comen",
        "sino_hero",
        "bionics"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "general electric",
          "value": "general_electric"
        },
        {
          "kind": "keyword",
          "pattern": "nihon kohden",
          "value": "nihon_kohden"
        },
        {
          "kind": "keyword",
          "pattern": "sino hero",
          "value": "sino_hero"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcriticare\\b",
          "value": "criticare"
        },
        {
          "kind": "keyword",
          "pattern": "\\bspacelabs\\b",
          "value": "spacelabs"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdra?eger\\b",
          "value": "drager"
        },
        {
          "kind": "keyword",
          "pattern": "phil+ips",
          "value": "philips"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmindray\\b",
          "value": "mindray"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdixtal\\b",
          "value": "dixtal"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbionet\\b",
