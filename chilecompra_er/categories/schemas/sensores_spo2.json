{
  "category_id": "sensores_spo2",
  "name": "Sensores SpO2",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 sensor)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo_paciente': 0.74, 'reutilizable': 0.14, 'tipo_sensor': 0.48, 'tecnologia': 0.22, 'marca_monitor': 0.68}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo_paciente",
      "role": "identity",
      "domain": [
        "adulto",
        "pediatrico",
        "infantil",
        "neonatal"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bneonat|\\bneopt\\b",
          "value": "neonatal"
        },
        {
          "kind": "keyword",
          "pattern": "\\binfantil\\b",
          "value": "infantil"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpediatrico\\b|\\bped\\b",
          "value": "pediatrico"
        },
        {
          "kind": "keyword",
          "pattern": "\\badulto\\b",
          "value": "adulto"
        }
      ],
      "curation_notes": "Identity: el tamano/grupo etario del sensor discrimina productos no intercambiables (adulto vs pediatrico vs neonatal); neonato/neopt se mapean a neonatal."
    },
    {
      "name": "reutilizable",
      "role": "identity",
      "domain": [
        "reusable",
        "desechable"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bdesechable\\b",
          "value": "desechable"
        },
        {
          "kind": "keyword",
          "pattern": "\\breusable\\b|\\breutilizable\\b",
          "value": "reusable"
        }
      ],
      "curation_notes": "Identity: reusable vs desechable es una distincion clinica y de precio fundamental entre sensores."
    },
    {
      "name": "tipo_sensor",
      "role": "identity",
      "domain": [
        "clip",
        "wrap",
        "dedo",
        "soft",
        "multisitio"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "punta suave|\\bsoft\\b|\\bsuave\\b",
          "value": "soft"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmultisitio\\b",
          "value": "multisitio"
        },
        {
          "kind": "keyword",
          "pattern": "\\bwrap\\b",
          "value": "wrap"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfinger\\b|\\bdedo\\b",
          "value": "dedo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bclip\\b|\\bpinza\\b",
          "value": "clip"
        }
      ],
      "curation_notes": "Identity: la forma/geometria del sensor (clip/pinza, wrap, dedo, soft, multisitio) define su aplicacion y no es intercambiable; pinza se unifica con clip."
    },
    {
      "name": "tecnologia",
      "role": "identity",
      "domain": [
        "masimo",
        "nellcor",
        "oximax"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bmass?imo\\b",
          "value": "masimo"
        },
        {
          "kind": "keyword",
          "pattern": "\\boximax\\b",
          "value": "oximax"
        },
        {
          "kind": "keyword",
          "pattern": "\\bnellcor\\b",
          "value": "nellcor"
        }
      ],
      "curation_notes": "Identity: la tecnologia de oximetria (masimo/massimo, nellcor, oximax) determina compatibilidad de senal y diferencia productos equivalentes en tamano/forma."
    },
    {
      "name": "marca_monitor",
      "role": "descriptive",
      "domain": [
        "general_electric",
        "criticare",
        "spacelabs",
        "philips",
        "drager",
        "mindray",
        "dixtal",
        "bionet",
        "comen",
        "nihon_kohden",
        "bionics",
        "hamilton"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "general electric",
          "value": "general_electric"
        },
        {
          "kind": "keyword",
          "pattern": "nihon kohden",
          "value": "nihon_kohden"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcriticare\\b",
          "value": "criticare"
        },
        {
          "kind": "keyword",
          "pattern": "\\bspacelabs\\b",
          "value": "spacelabs"
        },
        {
          "kind": "keyword",
          "pattern": "\\bphil+ips\\b",
          "value": "philips"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdraeger\\b|\\bdrager\\b",
          "value": "drager"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmindray\\b",
          "value": "mindray"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdixtal\\b",
          "value": "dixtal"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbionet\\b",
          "value": "bionet"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcomen\\b",
          "value": "comen"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbionics?\\b",
          "value": "bionics"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhamilton\\b",
          "value": "hamilton"
        }
      ],
      "curation_notes": "Descriptive: la marca del monitor compatible se normaliza para informacion pero no fija identidad, ya que la compatibilidad real la determina la tecnologia/conector y un mismo sensor sirve a varios modelos."
    }
  ]
}