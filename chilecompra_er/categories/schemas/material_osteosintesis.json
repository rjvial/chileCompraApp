{
  "category_id": "material_osteosintesis",
  "name": "Material de osteosintesis (placas y tornillos)",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 pieza de osteosintesis)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo_item': 0.96, 'material': 0.28, 'diametro': 0.56, 'bloqueo': 0.3, 'tipo_rosca': 0.3, 'anatomia': 0.48}, illegal extractions 0.",
    "Fix-D part2: numeric domains regenerated — canonicalized to one unit, leading zeros normalized, corpus-observed values (>=25) added."
  ],
  "attribute_defs": [
    {
      "name": "tipo_item",
      "role": "identity",
      "domain": [
        "placa",
        "tornillo",
        "clavo_endomedular",
        "tapon",
        "aguja_kirschner",
        "alambre",
        "arandela",
        "broca",
        "corchetera",
        "instrumental"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bplaca",
          "value": "placa"
        },
        {
          "kind": "keyword",
          "pattern": "\\bclavo\\b",
          "value": "clavo_endomedular"
        },
        {
          "kind": "keyword",
          "pattern": "\\btapon\\b",
          "value": "tapon"
        },
        {
          "kind": "keyword",
          "pattern": "\\btornillo",
          "value": "tornillo"
        },
        {
          "kind": "keyword",
          "pattern": "\\baguja",
          "value": "aguja_kirschner"
        },
        {
          "kind": "keyword",
          "pattern": "\\balambre\\b",
          "value": "alambre"
        },
        {
          "kind": "keyword",
          "pattern": "\\barandela",
          "value": "arandela"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbroca",
          "value": "broca"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcorchetera\\b",
          "value": "corchetera"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(alicate|caja|cajas|instrumental)\\b",
          "value": "instrumental"
        }
      ],
      "curation_notes": "Identity: tipo de pieza de osteosintesis; placa primero porque los kits placa+tornillo son producto placa, tapon antes que tornillo (tornillo de cierre) y tornillo antes que aguja (kits con 1 aguja). Dominio cerrado de piezas observadas."
    },
    {
      "name": "material",
      "role": "identity",
      "domain": [
        "titanio",
        "acero"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "titan",
          "value": "titanio"
        },
        {
          "kind": "keyword",
          "pattern": "\\bacero\\b",
          "value": "acero"
        }
      ],
      "curation_notes": "Identity: distingue implantes de titanio vs acero (productos distintos); patron 'titan' cubre titanio/titaneo. En 'acero o titanio' gana titanio por orden."
    },
    {
      "name": "diametro",
      "role": "identity",
      "domain": [
        "0.6mm",
        "1mm",
        "1.1mm",
        "1.2mm",
        "1.3mm",
        "1.5mm",
        "1.6mm",
        "1.7mm",
        "1.8mm",
        "2mm",
        "2.3mm",
        "2.4mm",
        "2.5mm",
        "2.6mm",
        "2.7mm",
        "3mm",
        "3.2mm",
        "3.5mm",
        "3.7mm",
        "4mm",
        "4.5mm",
        "5mm",
        "5.5mm",
        "6mm",
        "6.5mm",
        "7mm",
        "7.3mm"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d\\.\\d)\\b",
          "template": "{1}mm"
        }
      ],
      "curation_notes": "Identity: diametro nominal del implante (placa/tornillo/clavo/aguja). Los diametros son decimales (3.5, 6.5) mientras largos y agujeros son enteros, asi \\d.\\d los discrimina; el dominio filtra capturas espurias.",
      "unit": "mm"
    },
    {
      "name": "bloqueo",
      "role": "identity",
      "domain": [
        "bloqueada",
        "no_bloqueada"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "no\\s+bloquead",
          "value": "no_bloqueada"
        },
        {
          "kind": "keyword",
          "pattern": "bloquead|\\blcp\\b",
          "value": "bloqueada"
        }
      ],
      "curation_notes": "Identity: placa/tornillo bloqueado vs no bloqueado son productos distintos; 'no bloquead' primero por especificidad, LCP implica bloqueada."
    },
    {
      "name": "tipo_rosca",
      "role": "identity",
      "domain": [
        "cortical",
        "esponjosa",
        "canulado"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "canulad",
          "value": "canulado"
        },
        {
          "kind": "keyword",
          "pattern": "cortical",
          "value": "cortical"
        },
        {
          "kind": "keyword",
          "pattern": "esponjosa",
          "value": "esponjosa"
        }
      ],
      "curation_notes": "Identity: tipo de tornillo segun rosca/diseno (cortical/esponjosa/canulado) distingue productos; solo aplica a tornillos, vacio para otras piezas."
    },
    {
      "name": "anatomia",
      "role": "descriptive",
      "domain": [
        "clavicula",
        "calcaneo",
        "tibia",
        "humero",
        "femur",
        "cadera",
        "pelvis",
        "mano",
        "pie",
        "metacarpiano",
        "maxilo_facial"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "maxilo",
          "value": "maxilo_facial"
        },
        {
          "kind": "keyword",
          "pattern": "metacarp",
          "value": "metacarpiano"
        },
        {
          "kind": "keyword",
          "pattern": "clavicula",
          "value": "clavicula"
        },
        {
          "kind": "keyword",
          "pattern": "calcaneo",
          "value": "calcaneo"
        },
        {
          "kind": "keyword",
          "pattern": "\\btibia\\b",
          "value": "tibia"
        },
        {
          "kind": "keyword",
          "pattern": "humero",
          "value": "humero"
        },
        {
          "kind": "keyword",
          "pattern": "femur",
          "value": "femur"
        },
        {
          "kind": "keyword",
          "pattern": "cadera",
          "value": "cadera"
        },
        {
          "kind": "keyword",
          "pattern": "pelvis",
          "value": "pelvis"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmano\\b",
          "value": "mano"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpie\\b",
          "value": "pie"
        }
      ],
      "curation_notes": "Descriptive: region anatomica de uso; se normaliza para enriquecer pero no fija identidad (la misma pieza sirve a varias regiones). Orden de especifico a general."
    }
  ]
}
