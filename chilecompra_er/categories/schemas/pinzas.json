        "adson",
        "magill",
        "pozzi",
        "boseman",
        "biopsia",
        "hemostatica",
        "bipolar",
        "kocher",
        "hartmann",
        "yasargil"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bkelly\\b",
          "value": "kelly"
        },
        {
          "kind": "keyword",
          "pattern": "\\boverholt\\b",
          "value": "overholt"
        },
        {
          "kind": "keyword",
          "pattern": "\\bad[i]?son\\b",
          "value": "adson"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmagill\\b",
          "value": "magill"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpozzi\\b",
          "value": "pozzi"
        },
        {
          "kind": "keyword",
          "pattern": "\\bboseman\\b",
          "value": "boseman"
        },
        {
          "kind": "keyword",
          "pattern": "\\byasargil\\b",
          "value": "yasargil"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhartmann\\b",
          "value": "hartmann"
        },
        {
          "kind": "keyword",
          "pattern": "\\bkocher\\b",
          "value": "kocher"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmosquito\\b|\\bmoskito\\b",
          "value": "mosquito"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbiopsia\\b",
          "value": "biopsia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdiseccion\\b",
          "value": "diseccion"
        },
        {
          "kind": "keyword",
          "pattern": "\\bhemostatic[ao]s?\\b",
          "value": "hemostatica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbipolar\\b",
          "value": "bipolar"
        },
        {
          "kind": "keyword",
          "pattern": "\\banatomic[ao]s?\\b",
          "value": "anatomica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bquirurgic[ao]s?\\b",
          "value": "quirurgica"
        }
      ],
      "curation_notes": "Identity: el modelo/tipo de pinza (eponimo o funcional) es el principal discriminante de identidad en la categoria; dominio cerrado de tipos observados, eponimos primero y tipos genericos al final."
    },
    {
      "name": "forma",
      "role": "identity",
      "domain": [
        "recta",
        "curva",
        "bayoneta",
        "biangulada"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bbayoneta\\b",
          "value": "bayoneta"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbiangulada\\b",
          "value": "biangulada"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcurv\\w*\\b",
          "value": "curva"
        },
        {
          "kind": "keyword",
          "pattern": "\\brect[ao]s?\\b",
          "value": "recta"
        }
      ],
      "curation_notes": "Identity: la curvatura/forma de la mandibula (recta vs curva, y formas especiales) distingue productos del mismo tipo; dominio cerrado, formas especificas antes que recta/curva."
    },
    {
      "name": "longitud",
      "role": "identity",
      "domain": [
        "8cm",
        "9cm",
        "10cm",
        "11cm",
        "12cm",
        "13cm",
        "14cm",
        "15cm",
        "16cm",
        "17cm",
        "18cm",
        "19cm",
        "20cm",
        "21cm",
        "22cm",
        "23cm",
        "24cm",
        "25cm",
        "26cm",
        "160cm",
        "230cm"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,3})\\s*cms?\\b",
          "template": "{1}cm"
        }
      ],
      "curation_notes": "Identity: el largo en cm es una dimension fisica que discrimina entre variantes de un mismo tipo (12/14/15 cm); dominio cerrado con rango estandar generoso mas largos de instrumentos endoscopicos.",
      "unit": "cm"
    },
    {
      "name": "material",
      "role": "descriptive",
      "domain": [
        "acero_inoxidable",
        "titanio",
        "silicona"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\btitanio\\b",
          "value": "titanio"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsilicona\\b",
          "value": "silicona"
        },
        {
          "kind": "keyword",
          "pattern": "\\bacero\\b",
          "value": "acero_inoxidable"
        }
      ],
      "curation_notes": "Descriptive: el material se normaliza pero casi siempre es acero inoxidable y no discrimina identidad de manera fiable; dominio cerrado de materiales observados."
    },
    {
      "name": "esterilizacion",
      "role": "descriptive",
      "domain": [
        "desechable",
        "reutilizable",
        "esterilizable",
        "esteril"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bdesechable\\b",
          "value": "desechable"
        },
        {
          "kind": "keyword",
          "pattern": "\\breutilizable\\b",
          "value": "reutilizable"
        },
        {
          "kind": "keyword",
          "pattern": "\\bester[il]+izable\\b|\\bautoclavable\\b|\\bautoclabable\\b",
          "value": "esterilizable"
        },
        {
          "kind": "keyword",
          "pattern": "\\besteril\\b",
          "value": "esteril"
        }
      ],
      "curation_notes": "Descriptive: la condicion de esterilidad/reuso se normaliza pero no fija la identidad del instrumento; dominio cerrado, valores especificos (desechable/reutilizable/esterilizable) antes que esteril generico."
    }
  ]
