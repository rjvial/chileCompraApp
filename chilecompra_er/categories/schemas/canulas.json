      "rules": [
        {
          "kind": "keyword",
          "pattern": "sin balon",
          "value": "sin_balon"
        },
        {
          "kind": "keyword",
          "pattern": "con balon|\\bbalon\\b",
          "value": "con_balon"
        }
      ],
      "curation_notes": "identity: la presencia de balon distingue canulas de traqueostomia equivalentes en calibre; regla 'sin balon' antes que 'con balon' para evitar falso positivo."
    },
