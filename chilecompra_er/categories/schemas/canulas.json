{
  "category_id": "canulas",
  "name": "Cánulas",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 canula)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 0.76, 'calibre_french': 0.28, 'calibre_gauge': 0.14, 'balon': 0.1, 'material': 0.12, 'longitud': 0.22}, illegal extractions 5.",
    "Fix-D part2: numeric domains regenerated — canonicalized to one unit, leading zeros normalized, corpus-observed values (>=25) added."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "frazier",
        "hemosuccion",
        "hidrodiseccion",
        "endouterina",
        "oftalmologica",
        "mayo",
        "traqueostomia",
        "intravena",
        "vaso",
        "arterial",
        "venosa",
        "ecmo",
        "aspiracion"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "frazier",
          "value": "frazier"
        },
        {
          "kind": "keyword",
          "pattern": "hemosuccion",
          "value": "hemosuccion"
        },
        {
          "kind": "keyword",
          "pattern": "hidrodiseccion",
          "value": "hidrodiseccion"
        },
        {
          "kind": "keyword",
          "pattern": "endouterina",
          "value": "endouterina"
        },
        {
          "kind": "keyword",
          "pattern": "oftalmologica",
          "value": "oftalmologica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmayo\\b",
          "value": "mayo"
        },
        {
          "kind": "keyword",
          "pattern": "traqueo|\\btqt\\b",
          "value": "traqueostomia"
        },
        {
          "kind": "keyword",
          "pattern": "intravena|\\bi v\\b",
          "value": "intravena"
        },
        {
          "kind": "keyword",
          "pattern": "de vaso",
          "value": "vaso"
        },
        {
          "kind": "keyword",
          "pattern": "arterial|arteria",
          "value": "arterial"
        },
        {
          "kind": "keyword",
          "pattern": "venosa",
          "value": "venosa"
        },
        {
          "kind": "keyword",
          "pattern": "ecmo",
          "value": "ecmo"
        },
        {
          "kind": "keyword",
          "pattern": "aspiracion",
          "value": "aspiracion"
        }
      ],
      "curation_notes": "identity: el tipo funcional/anatomico de canula es el principal discriminante (frazier vs traqueostomia vs ecmo vs intravena, etc.); dominio cerrado a los tipos observados, reglas ordenadas de tipo especifico a vascular general."
    },
    {
      "name": "calibre_french",
      "role": "identity",
      "domain": [
        "5fr",
        "6fr",
        "7fr",
        "8fr",
        "9fr",
