      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*ga\\b",
          "template": "{1}g"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*g\\b",
          "template": "{1}g"
        }
      ],
      "curation_notes": "identity: el calibre Gauge distingue canulas intravenosas y de hidrodiseccion (16-27 g); separado del French por ser sistema de medida distinto.",
      "unit": "g"
    },
    {
      "name": "balon",
      "role": "identity",
      "domain": [
        "con_balon",
        "sin_balon"
