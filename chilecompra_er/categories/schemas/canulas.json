        "30fr",
        "31fr",
        "32fr",
        "34fr",
        "40fr"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*fr\\b",
          "template": "{1}fr"
        },
        {
          "kind": "regex",
          "pattern": "\\bch\\s*(\\d{1,2})\\b",
          "template": "{1}fr"
        }
      ],
      "curation_notes": "identity: el calibre French (fr/ch) distingue canulas vasculares y ECMO (15-27 fr) y de drenaje; dominio cerrado a los calibres observados.",
      "unit": "fr"
    },
    {
      "name": "calibre_gauge",
      "role": "identity",
      "domain": [
        "14g",
