    {
      "name": "formato",
      "role": "identity",
      "domain": [
        "placa",
        "tubo",
        "frasco",
        "caldo"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bcaldo\\b",
          "value": "caldo"
        },
        {
          "kind": "keyword",
          "pattern": "\\btubo\\b|agar\\s+inclinado|tapa\\s+rosca",
          "value": "tubo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfrasco\\b",
          "value": "frasco"
        },
        {
          "kind": "keyword",
          "pattern": "\\bplacas?\\b",
          "value": "placa"
        }
      ],
      "curation_notes": "Identity: el formato fisico (placa vs tubo vs caldo vs frasco) discrimina presentaciones no intercambiables del mismo o distinto medio; dominio cerrado por los formatos observados."
    },
    {
      "name": "diametro_placa",
      "role": "descriptive",
      "domain": [
        "90mm"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(90)\\s*mm\\b",
          "template": "{1}mm"
        }
      ],
      "curation_notes": "Descriptive: el diametro (90 mm) es estandar y casi constante en las placas, no discrimina identidad; se normaliza pero no participa en la igualdad.",
      "unit": "mm"
    },
    {
      "name": "esteril",
      "role": "descriptive",
      "domain": [
        "esteril"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "esteril",
          "value": "esteril"
        }
      ],
      "curation_notes": "Descriptive: la esterilidad es atributo de calidad esperado y poco discriminante entre medios; se normaliza pero no fija identidad."
    }
