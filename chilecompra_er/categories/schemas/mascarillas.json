{
  "category_id": "mascarillas",
  "name": "Mascarillas",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 mascarilla)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 0.84, 'grupo_etario': 0.16, 'nivel_filtracion': 0.1, 'talla': 0.16, 'pliegues': 0.06, 'material': 0.06}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "quirurgica",
        "laringea",
        "oxigeno",
        "venturi",
        "reservorio",
        "traqueostomia",
        "rcp",
        "particulas",
        "nebulizacion",
        "facial"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\blaringea\\b",
          "value": "laringea"
        },
        {
          "kind": "keyword",
          "pattern": "traqueostom",
          "value": "traqueostomia"
        },
        {
          "kind": "keyword",
          "pattern": "venturi",
          "value": "venturi"
        },
        {
          "kind": "keyword",
          "pattern": "reservorio",
          "value": "reservorio"
        },
        {
          "kind": "keyword",
          "pattern": "pocket|resu[cs]citacion|\\brcp\\b",
          "value": "rcp"
        },
        {
          "kind": "keyword",
          "pattern": "particulas|respirador",
          "value": "particulas"
        },
        {
          "kind": "keyword",
          "pattern": "nebuliza|aerosol",
          "value": "nebulizacion"
        },
        {
          "kind": "keyword",
          "pattern": "oxigeno",
          "value": "oxigeno"
        },
        {
          "kind": "keyword",
          "pattern": "facial",
          "value": "facial"
        },
        {
          "kind": "keyword",
          "pattern": "desechable|quirurgic|examen|pliegues",
          "value": "quirurgica"
        }
      ],
      "curation_notes": "Identidad funcional del producto; discrimina familias claramente distintas (laringea, oxigeno, traqueostomia, quirurgica, etc.); reglas de subtipo (venturi, reservorio) antes que el general oxigeno."
    },
    {
      "name": "grupo_etario",
      "role": "identity",
      "domain": [
        "adulto",
        "pediatrico",
        "infantil",
        "neonatal"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "neonat",
          "value": "neonatal"
        },
        {
          "kind": "keyword",
          "pattern": "pediatric",
          "value": "pediatrico"
        },
        {
          "kind": "keyword",
          "pattern": "infantil",
          "value": "infantil"
        },
        {
          "kind": "keyword",
          "pattern": "adulto",
          "value": "adulto"
        }
      ],
      "curation_notes": "Identidad: una mascarilla adulto y una pediatrica son productos distintos; dominio cerrado por rangos etarios estandar."
    },
    {
      "name": "nivel_filtracion",
      "role": "identity",
      "domain": [
        "n95",
        "n100",
        "p3"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bn\\s*100\\b",
          "value": "n100"
        },
        {
          "kind": "keyword",
          "pattern": "\\bn\\s*95\\b",
          "value": "n95"
        },
        {
          "kind": "keyword",
          "pattern": "\\bp\\s*3\\b",
          "value": "p3"
        }
      ],
      "curation_notes": "Identidad: el grado de filtracion respiratoria (n95, n100, p3/ffp3) distingue respiradores entre si; n100 antes que n95 por especificidad."
    },
    {
      "name": "talla",
      "role": "identity",
      "domain": [
        "0.5",
        "1",
        "1.5",
        "2",
        "2.5",
        "3",
        "3.5",
        "4",
        "4.5",
        "talla_s",
        "talla_m",
        "talla_l"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "laringea\\s+n\\s+(\\d\\.?\\d?)",
          "template": "{1}"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla\\s*s\\b",
          "value": "talla_s"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla\\s*m\\b",
          "value": "talla_m"
        },
        {
          "kind": "keyword",
          "pattern": "\\btalla\\s*l\\b",
          "value": "talla_l"
        }
      ],
      "curation_notes": "Identidad: el numero de mascarilla laringea (0.5-4.5, segun peso del paciente) y las tallas de mascarilla facial son discriminantes; regex captura el numero tras 'laringea n'."
    },
    {
      "name": "pliegues",
      "role": "identity",
      "domain": [
        "3pliegues",
        "4pliegues"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "(\\d)\\s*pliegues",
          "template": "{1}pliegues"
        }
      ],
      "curation_notes": "Identidad: el numero de pliegues (3 vs 4) distingue variantes de mascarilla quirurgica desechable observadas en la categoria."
    },
    {
      "name": "material",
      "role": "descriptive",
      "domain": [
        "latex",
        "libre_de_latex",
        "pvc",
        "tela_no_tejida"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "tela\\s+no\\s+tejida",
          "value": "tela_no_tejida"
        },
        {
          "kind": "keyword",
          "pattern": "libre\\s+de\\s+latex",
          "value": "libre_de_latex"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpvc\\b",
          "value": "pvc"
        },
        {
          "kind": "keyword",
          "pattern": "\\blatex\\b",
          "value": "latex"
        }
      ],
      "curation_notes": "Descriptivo: el material se normaliza pero no define identidad; 'libre de latex' antes que 'latex' para evitar captura erronea."
    }
  ]
}