{
  "category_id": "ecotomografos",
  "name": "Ecotomógrafos",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 ecotomografo)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo_objeto': 1.0, 'portabilidad': 0.1, 'modalidad': 0.16, 'aplicacion_clinica': 0.16, 'marca': 0.3, 'tipo_transductor': 0.08}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo_objeto",
      "role": "identity",
      "domain": [
        "equipo",
        "mantencion",
        "arriendo",
        "transductor",
        "reparacion",
        "repuestos"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\btransductor",
          "value": "transductor"
        },
        {
          "kind": "keyword",
          "pattern": "\\brepuesto",
          "value": "repuestos"
        },
        {
          "kind": "keyword",
          "pattern": "\\breparacion\\b",
          "value": "reparacion"
        },
        {
          "kind": "keyword",
          "pattern": "\\barriendo\\b",
          "value": "arriendo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmanten",
          "value": "mantencion"
        },
        {
          "kind": "keyword",
          "pattern": "\\becotomografo\\b|\\becografo\\b|\\bultrasonido\\b|\\bequipo\\b",
          "value": "equipo"
        }
      ],
      "curation_notes": "Identity: distingue la naturaleza del item (maquina vs servicio de mantencion/arriendo/reparacion vs accesorio transductor vs repuestos); discrimina entre productos de la categoria. Reglas ordenadas de especifica a general; equipo es el fallback."
    },
    {
      "name": "portabilidad",
      "role": "identity",
      "domain": [
        "portatil",
        "estatico"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bportatil\\b",
          "value": "portatil"
        },
        {
          "kind": "keyword",
          "pattern": "\\bestatico\\b",
          "value": "estatico"
        }
      ],
      "curation_notes": "Identity: portatil vs estatico es una distincion fisica real del equipo; sin coincidencia queda nulo (la mayoria no lo declara)."
    },
    {
      "name": "modalidad",
      "role": "identity",
      "domain": [
        "doppler_color",
        "doppler",
        "4d"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bdo+p+ler\\s+color\\b",
          "value": "doppler_color"
        },
        {
          "kind": "keyword",
          "pattern": "\\b4\\s*d\\b",
          "value": "4d"
        },
        {
          "kind": "keyword",
          "pattern": "\\bdo+p+ler\\b",
          "value": "doppler"
        }
      ],
      "curation_notes": "Identity: capacidad de imagen (doppler color, 4d, doppler) discrimina equipos de distinta gama. Patrones toleran la variante mal escrita 'doopler'; orden de mas especifico a general."
    },
    {
      "name": "aplicacion_clinica",
      "role": "descriptive",
      "domain": [
        "gineco_obstetrico",
        "multiproposito",
        "urgencia",
        "anestesia",
        "imagenologia"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "obstetric",
          "value": "gineco_obstetrico"
        },
        {
          "kind": "keyword",
          "pattern": "\\banestesia\\b",
          "value": "anestesia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bimagenologia\\b",
          "value": "imagenologia"
        },
        {
          "kind": "keyword",
          "pattern": "\\burgencia\\b",
          "value": "urgencia"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmultiproposito\\b",
          "value": "multiproposito"
        }
      ],
      "curation_notes": "Descriptive: el destino clinico se normaliza pero es demasiado ruidoso/variable para fijar identidad."
    },
    {
      "name": "marca",
      "role": "descriptive",
      "domain": [
        "philips",
        "ge",
        "samsung",
        "aloka",
        "vinno"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bphil+ips\\b",
          "value": "philips"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgeneral\\s+electric\\b|\\bg\\s+electric\\b|\\bge\\b",
          "value": "ge"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsamsung\\b",
          "value": "samsung"
        },
        {
          "kind": "keyword",
          "pattern": "\\baloka\\b",
          "value": "aloka"
        },
        {
          "kind": "keyword",
          "pattern": "\\bvinno\\b",
          "value": "vinno"
        }
      ],
      "curation_notes": "Descriptive: la marca se normaliza para enriquecer, pero no participa en la igualdad de identidad."
    },
    {
      "name": "tipo_transductor",
      "role": "descriptive",
      "domain": [
        "lineal",
        "convexo",
        "intravaginal"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bintravaginal\\b",
          "value": "intravaginal"
        },
        {
          "kind": "keyword",
          "pattern": "\\bconvexo\\b",
          "value": "convexo"
        },
        {
          "kind": "keyword",
          "pattern": "\\blineal\\b",
          "value": "lineal"
        }
      ],
      "curation_notes": "Descriptive: tipo de transductor/sonda mencionado en accesorios; se normaliza pero no se usa como clave de identidad del equipo."
    }
  ]
}