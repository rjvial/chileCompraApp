      "curation_notes": "Forma/uso funcional de la sabana; discrimina identidad (encimera vs perforada vs cubre_camilla vs quirurgica). Dominio cerrado a los tipos observados; primera regla mas especifica gana."
    },
    {
      "name": "material",
      "role": "identity",
      "domain": [
        "crea",
        "algodon",
        "poliester",
        "algodon_poliester",
        "microfibra",
        "polipropileno",
        "sms"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bmicrofibra\\b",
          "value": "microfibra"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpolipropileno\\b",
          "value": "polipropileno"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsms\\b",
          "value": "sms"
        },
        {
          "kind": "keyword",
          "pattern": "(?:poliester[\\s\\S]*(?:algodon|crea)|(?:algodon|crea)[\\s\\S]*poliester)",
          "value": "algodon_poliester"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpoliester\\b",
          "value": "poliester"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcrea\\b",
          "value": "crea"
        },
        {
          "kind": "keyword",
          "pattern": "\\balgodon\\b",
          "value": "algodon"
        }
      ],
      "curation_notes": "Composicion textil; discrimina identidad (crea/algodon vs poliester vs mezcla vs polipropileno vs sms desechable). La mezcla algodon/crea+poliester se evalua antes que los puros para no perder el blend."
    },
    {
      "name": "color",
      "role": "identity",
      "domain": [
        "verde",
        "blanco",
        "crudo",
        "azul"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bverde\\b",
          "value": "verde"
        },
        {
          "kind": "keyword",
          "pattern": "\\bazul\\b",
          "value": "azul"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcrud[ao]\\b",
          "value": "crudo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bblanc[ao]\\b",
          "value": "blanco"
        }
      ],
      "curation_notes": "Color distingue uso (verde quirurgico vs blanco hospitalizacion vs crudo vs azul cubre_camilla); dominio cerrado a los colores observados."
    },
    {
      "name": "talla",
      "role": "identity",
      "domain": [
        "1_plaza",
        "1_5_plaza",
        "2_plazas"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "(?:1 1 2 plaza|11 2 plaza|plaza ½|plaza 1 2|plaza y media)",
          "value": "1_5_plaza"
        },
        {
          "kind": "keyword",
          "pattern": "2 plaza",
          "value": "2_plazas"
        },
        {
          "kind": "keyword",
          "pattern": "(?:una plaza|1 plaza|de plaza\\b)",
          "value": "1_plaza"
        }
      ],
      "curation_notes": "Tamano de cama para juegos de sabanas (plaza/1.5/2 plazas); discrimina identidad en sabanas domesticas. Vacio en sabanas clinicas dimensionadas en cm. Variante 1.5 evaluada primero por su escritura ambigua."
    },
    {
      "name": "esteril",
      "role": "identity",
      "domain": [
        "esteril"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\besteril\\b",
          "value": "esteril"
        }
      ],
      "curation_notes": "Marca esterilidad del campo quirurgico desechable; distingue identidad frente a la sabana no esteril (atributo vacio)."
    },
    {
      "name": "desechable",
      "role": "identity",
      "domain": [
        "desechable"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "(?:desechable|descartable)",
          "value": "desechable"
        }
      ],
      "curation_notes": "Distingue insumo de un solo uso frente a la ropa clinica reutilizable (atributo vacio); identidad porque cambia el producto y su base de precio."
    }
  ]
