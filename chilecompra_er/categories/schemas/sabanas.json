        "perforada",
        "cerrada",
        "elasticada",
        "cubre_camilla",
        "cubre_loneta",
        "arsenalera",
        "cefalica",
        "podalica",
        "lateral",
        "quirurgica",
        "lisa"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "cubre\\s+camilla",
          "value": "cubre_camilla"
        },
        {
          "kind": "keyword",
          "pattern": "cubre\\s+loneta",
          "value": "cubre_loneta"
        },
        {
          "kind": "keyword",
          "pattern": "\\barsenaler[ao]\\b",
          "value": "arsenalera"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcefalica\\b",
          "value": "cefalica"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpodalica\\b",
          "value": "podalica"
        },
        {
          "kind": "keyword",
          "pattern": "\\blateral\\b",
          "value": "lateral"
        },
        {
          "kind": "keyword",
          "pattern": "\\belasticada\\b",
          "value": "elasticada"
        },
        {
          "kind": "keyword",
          "pattern": "\\bperforad[ao]\\b",
          "value": "perforada"
        },
        {
          "kind": "keyword",
          "pattern": "\\bencimera\\b",
          "value": "encimera"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcerrada\\b",
          "value": "cerrada"
        },
        {
          "kind": "keyword",
          "pattern": "\\bquirurgica\\b",
          "value": "quirurgica"
        },
        {
          "kind": "keyword",
          "pattern": "\\blisa\\b",
          "value": "lisa"
        }
      ],
      "curation_notes": "identity: la forma/funcion de la sabana (encimera, perforada, cerrada, elasticada, cubre camilla, arsenalera, cefalica/podalica/lateral quirurgicas) distingue productos distintos dentro de la categoria."
    },
    {
      "name": "material",
      "role": "identity",
      "domain": [
        "crea",
        "algodon",
        "poliester",
        "microfibra",
        "polipropileno",
        "sms"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bsms\\b",
          "value": "sms"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpolipropileno\\b",
          "value": "polipropileno"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcrea\\b",
          "value": "crea"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmicrofibra\\b",
          "value": "microfibra"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpoliester\\b",
          "value": "poliester"
        },
        {
          "kind": "keyword",
          "pattern": "\\balgodon\\b",
          "value": "algodon"
        }
      ],
      "curation_notes": "identity: el material/fibra (crea, algodon, poliester, microfibra, polipropileno, sms) discrimina identidad; en mezclas gana la fibra mas especifica segun orden de reglas."
    },
    {
      "name": "color",
      "role": "identity",
      "domain": [
        "blanco",
        "verde",
        "azul",
        "crudo"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bverde\\b",
          "value": "verde"
        },
        {
          "kind": "keyword",
          "pattern": "\\bazul\\b",
          "value": "azul"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcrud[ao]\\b",
          "value": "crudo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bblanc[ao]\\b",
          "value": "blanco"
        }
      ],
      "curation_notes": "identity: el color funcional (verde quirurgico, blanco hospitalario, azul cubre camilla, crudo) discrimina productos en uso clinico."
    },
    {
      "name": "esterilidad",
      "role": "identity",
      "domain": [
        "esteril",
        "no_esteril"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\besteril\\b",
          "value": "esteril"
        }
      ],
      "curation_notes": "identity: ser esteril vs no esteril cambia el producto (sabana quirurgica esteril vs sabana hospitalaria); solo se asigna 'esteril' cuando el texto lo declara."
    },
    {
      "name": "desechable",
      "role": "descriptive",
      "domain": [
        "desechable",
        "reutilizable"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "desechable",
          "value": "desechable"
        }
      ],
      "curation_notes": "descriptive: se normaliza la condicion desechable/reutilizable como atributo informativo, sin participar en la igualdad para no fragmentar identidades ya fijadas por tipo y material."
