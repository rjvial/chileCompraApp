        },
        {
          "kind": "keyword",
          "pattern": "cubre loneta",
          "value": "cubre_loneta"
        },
        {
          "kind": "keyword",
          "pattern": "arsenaler",
          "value": "arsenalera"
        },
        {
          "kind": "keyword",
          "pattern": "encimera",
          "value": "encimera"
        },
        {
          "kind": "keyword",
          "pattern": "perforad",
          "value": "perforada"
        },
        {
          "kind": "keyword",
          "pattern": "cerrada",
          "value": "cerrada"
        },
        {
          "kind": "keyword",
          "pattern": "cefalica",
          "value": "cefalica"
        },
        {
          "kind": "keyword",
          "pattern": "podalica",
          "value": "podalica"
        },
        {
          "kind": "keyword",
          "pattern": "\\blateral\\b",
          "value": "lateral"
        },
        {
          "kind": "keyword",
          "pattern": "hospitalizacion",
          "value": "hospitalizacion"
        },
        {
          "kind": "keyword",
          "pattern": "quirurgica",
          "value": "quirurgica"
        },
        {
          "kind": "keyword",
