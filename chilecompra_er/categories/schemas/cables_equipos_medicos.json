{
  "category_id": "cables_equipos_medicos",
  "name": "Cables de interfaz/paciente para equipos médicos",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 cable)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo_cable': 0.32, 'conexion': 0.04, 'longitud': 0.06, 'marca_equipo': 0.3}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo_cable",
      "role": "identity",
      "domain": [
        "ecg",
        "spo2",
        "presion_invasiva",
        "interfaz",
        "paciente",
        "bipolar",
        "electrodo",
        "tens"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "presion\\s+invasiva",
          "value": "presion_invasiva"
        },
        {
          "kind": "keyword",
          "pattern": "\\bspo\\s*2\\b",
          "value": "spo2"
        },
        {
          "kind": "keyword",
          "pattern": "\\becg\\b",
          "value": "ecg"
        },
        {
          "kind": "keyword",
          "pattern": "\\bbipolar\\b",
          "value": "bipolar"
        },
        {
          "kind": "keyword",
          "pattern": "\\btens\\b",
          "value": "tens"
        },
        {
          "kind": "keyword",
          "pattern": "\\belectrodo\\b",
          "value": "electrodo"
        },
        {
          "kind": "keyword",
          "pattern": "\\binterfaz\\b",
          "value": "interfaz"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpaciente\\b",
          "value": "paciente"
        }
      ],
      "curation_notes": "Identity: la funcion/senal del cable (ecg, spo2, presion invasiva, bipolar, tens, electrodo, interfaz, paciente) es lo que distingue un cable de otro; dominio cerrado segun tipos observados."
    },
    {
      "name": "conexion",
      "role": "identity",
      "domain": [
        "2_pin",
        "5_pin",
        "12_pin",
        "3_pares",
        "5_pares"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*pin\\b",
          "template": "{1}_pin"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*pares\\b",
          "template": "{1}_pares"
        }
      ],
      "curation_notes": "Identity: la configuracion del conector (numero de pines o pares) discrimina compatibilidad/identidad; dominio cerrado con valores estandar observados."
    },
    {
      "name": "longitud",
      "role": "identity",
      "domain": [
        "1.5m",
        "12ft"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d+(?:\\.\\d+)?)\\s*mts?\\b",
          "template": "{1}m"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d+(?:\\.\\d+)?)\\s*ft\\b",
          "template": "{1}ft"
        }
      ],
      "curation_notes": "Identity: el largo del cable cuando se especifica distingue referencias; dominio cerrado a las longitudes observadas (mts/ft).",
      "unit": "m"
    },
    {
      "name": "marca_equipo",
      "role": "descriptive",
      "domain": [
        "mindray",
        "general_electric",
        "spacelabs",
        "welch_allyn",
        "nihon_koden",
        "drager",
        "masimo",
        "valleylab",
        "alcon",
        "cadwell"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "general\\s+electric",
          "value": "general_electric"
        },
        {
          "kind": "keyword",
          "pattern": "welch\\s+allyn",
          "value": "welch_allyn"
        },
        {
          "kind": "keyword",
          "pattern": "nihon\\s+kode?n",
          "value": "nihon_koden"
        },
        {
          "kind": "keyword",
          "pattern": "\\bspacelabs\\b",
          "value": "spacelabs"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmindray\\b",
          "value": "mindray"
        },
        {
          "kind": "keyword",
          "pattern": "drag?uer|\\bdrager\\b",
          "value": "drager"
        },
        {
          "kind": "keyword",
          "pattern": "mas+imo",
          "value": "masimo"
        },
        {
          "kind": "keyword",
          "pattern": "vall?ay?lab|valleylab",
          "value": "valleylab"
        },
        {
          "kind": "keyword",
          "pattern": "\\balcon\\b",
          "value": "alcon"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcadwell\\b",
          "value": "cadwell"
        }
      ],
      "curation_notes": "Descriptive: la marca del equipo al que se conecta se normaliza para contexto pero no fija identidad por si sola (un mismo cable puede listarse con distintas marcas/modelos)."
    }
  ]
}