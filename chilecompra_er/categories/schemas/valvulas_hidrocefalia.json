{
  "category_id": "valvulas_hidrocefalia",
  "name": "Valvulas para hidrocefalia",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 valvula)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 1.0, 'presion': 0.8, 'talla': 0.86, 'antisifon': 0.08, 'esteril': 0.14}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "valvula",
        "kit",
        "cateter",
        "set",
        "pasador"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bpasador\\b",
          "value": "pasador"
        },
        {
          "kind": "keyword",
          "pattern": "\\bset\\b",
          "value": "set"
        },
        {
          "kind": "keyword",
          "pattern": "\\bkit\\b",
          "value": "kit"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcat[ae]ter\\b",
          "value": "cateter"
        },
        {
          "kind": "keyword",
          "pattern": "\\bvalvula\\b",
          "value": "valvula"
        }
      ],
      "curation_notes": "identity: distingue el tipo de articulo (valvula, kit completo, cateter suelto, set o pasador); discrimina productos heterogeneos del mismo convenio."
    },
    {
      "name": "presion",
      "role": "identity",
      "domain": [
        "baja",
        "media",
        "alta",
        "programable"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bprogramable\\b",
          "value": "programable"
        },
        {
          "kind": "keyword",
          "pattern": "\\bregulable\\b",
          "value": "programable"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpresion baja\\b",
          "value": "baja"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpresion media\\b",
          "value": "media"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpresion alta\\b",
          "value": "alta"
        },
        {
          "kind": "keyword",
          "pattern": "\\balta presion\\b",
          "value": "alta"
        },
        {
          "kind": "keyword",
          "pattern": "\\bp b\\b",
          "value": "baja"
        },
        {
          "kind": "keyword",
          "pattern": "\\bp m\\b",
          "value": "media"
        },
        {
          "kind": "keyword",
          "pattern": "\\bp a\\b",
          "value": "alta"
        }
      ],
      "curation_notes": "identity: nivel/tipo de presion (baja/media/alta o programable-regulable) es el atributo clinico que mas discrimina las valvulas; programable y regulable se canonizan iguales."
    },
    {
      "name": "talla",
      "role": "identity",
      "domain": [
        "neonatal",
        "pediatrico",
        "adulto",
        "ultra_small",
        "small",
        "regular"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bultra s(?:mall)?\\b",
          "value": "ultra_small"
        },
        {
          "kind": "keyword",
          "pattern": "\\bneonatal\\b",
          "value": "neonatal"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpediatric[oa]\\b",
          "value": "pediatrico"
        },
        {
          "kind": "keyword",
          "pattern": "\\badult[oa]\\b",
          "value": "adulto"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsmall\\b",
          "value": "small"
        },
        {
          "kind": "keyword",
          "pattern": "\\bregular\\b",
          "value": "regular"
        }
      ],
      "curation_notes": "identity: talla/grupo etario del dispositivo (neonatal, pediatrico, adulto o small/regular/ultra_small); ultra_small antes que small para evitar captura parcial."
    },
    {
      "name": "antisifon",
      "role": "identity",
      "domain": [
        "con_antisifon",
        "sin_antisifon"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bsin dispositivo antisifon\\b",
          "value": "sin_antisifon"
        },
        {
          "kind": "keyword",
          "pattern": "\\bantisifon\\b",
          "value": "con_antisifon"
        }
      ],
      "curation_notes": "identity: presencia o ausencia de dispositivo antisifon diferencia variantes de la misma valvula programable; regla 'sin' antes que la general."
    },
    {
      "name": "esteril",
      "role": "descriptive",
      "domain": [
        "esteril"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\besteril\\b",
          "value": "esteril"
        }
      ],
      "curation_notes": "descriptive: la esterilidad se normaliza pero no define identidad porque casi todos los dispositivos implantables son esteriles."
    }
  ]
}