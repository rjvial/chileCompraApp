{
  "category_id": "drenajes_quirurgicos",
  "name": "Drenajes quirúrgicos",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 drenaje)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo': 0.68, 'calibre': 0.3, 'material': 0.16, 'diametro': 0.12, 'esteril': 0.12}, illegal extractions 0.",
    "Fix-D part2: numeric domains regenerated — canonicalized to one unit, leading zeros normalized, corpus-observed values (>=25) added."
  ],
  "attribute_defs": [
    {
      "name": "tipo",
      "role": "identity",
      "domain": [
        "penrose",
        "blake",
        "vesical",
        "ventricular",
        "toracico",
        "biliar",
        "aspiracion",
        "multilumen",
        "multiproposito"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "penro(s)?se|penrosse",
          "value": "penrose"
        },
        {
          "kind": "keyword",
          "pattern": "\\bblake\\b",
          "value": "blake"
        },
        {
          "kind": "keyword",
          "pattern": "vesical|cystofix|cistofix",
          "value": "vesical"
        },
        {
          "kind": "keyword",
          "pattern": "ventricular",
          "value": "ventricular"
        },
        {
          "kind": "keyword",
          "pattern": "biliar",
          "value": "biliar"
        },
        {
          "kind": "keyword",
          "pattern": "multilumen",
          "value": "multilumen"
        },
        {
          "kind": "keyword",
          "pattern": "multiproposito",
          "value": "multiproposito"
        },
        {
          "kind": "keyword",
          "pattern": "aspiracion",
          "value": "aspiracion"
        },
        {
          "kind": "keyword",
          "pattern": "torax|toraxico|toracico|toraxica|pleural",
          "value": "toracico"
        }
      ],
      "curation_notes": "Identity: el tipo clinico de drenaje distingue productos no intercambiables (penrose vs blake vs toracico, etc.); dominio cerrado de tipos observados en la categoria."
    },
    {
      "name": "calibre",
      "role": "identity",
      "domain": [
        "5fr",
        "6fr",
        "7fr",
        "8fr",
        "9fr",
        "10fr",
        "12fr",
        "14fr",
        "15fr",
        "16fr",
        "18fr",
        "19fr",
        "20fr",
        "21fr",
        "24fr",
        "28fr",
        "32fr"
      ],
      "rules": [
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*fr\\b",
          "template": "{1}fr"
        },
        {
          "kind": "regex",
          "pattern": "\\b(\\d{1,2})\\s*fx\\b",
          "template": "{1}fr"
        },
        {
          "kind": "regex",
          "pattern": "\\bch\\s*(\\d{1,2})\\b",
          "template": "{1}fr"
        }
      ],
      "curation_notes": "Identity: el calibre French (fr/charriere/fx) es la medida funcional que discrimina los drenajes tubulares; rango estandar generoso de calibres observados.",
      "unit": "fr"
    },
    {
      "name": "material",
      "role": "identity",
      "domain": [
        "silicona",
        "pur",
        "sintetico",
        "latex"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "silicona|siliconado|silicon",
          "value": "silicona"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpur\\b",
          "value": "pur"
        },
        {
          "kind": "keyword",
          "pattern": "sintetic[oa]",
          "value": "sintetico"
        },
        {
          "kind": "keyword",
          "pattern": "(?<!libre de )latex",
          "value": "latex"
        }
      ],
      "curation_notes": "Identity: el material define compatibilidad clinica (silicona vs latex vs pur); regla de latex usa lookbehind para no capturar 'libre de latex'."
    },
    {
      "name": "diametro",
      "role": "identity",
      "domain": [
        "0.6cm",
        "1.27cm",
        "1.3cm",
        "1.9cm"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\b12\\.7\\s*mm\\b",
          "value": "12.7mm"
        },
        {
          "kind": "keyword",
          "pattern": "\\b0\\.6\\b",
          "value": "0.6cm",
          "requires": "\\bcm\\b|diam|drenaje|\\bfr\\b|french"
        },
        {
          "kind": "keyword",
          "pattern": "\\b1\\.30?\\b",
          "value": "1.3cm",
          "requires": "\\bcm\\b|diam|drenaje|\\bfr\\b|french"
        },
        {
          "kind": "keyword",
          "pattern": "\\b1\\.90?\\b",
          "value": "1.9cm",
          "requires": "\\bcm\\b|diam|drenaje|\\bfr\\b|french"
        }
      ],
      "curation_notes": "Identity: los penrose se diferencian por diametro (1/4, 1/2, 3/4 pulgada -> 0.6/1.3/1.9 cm) y no por calibre fr; dominio cerrado de diametros observados."
    },
    {
      "name": "esteril",
      "role": "descriptive",
      "domain": [
        "esteril"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "esteril",
          "value": "esteril"
        }
      ],
      "curation_notes": "Descriptive: la mencion de esterilidad se normaliza pero no discrimina identidad porque es atributo casi universal del rubro y poco consignado."
    }
  ]
}
