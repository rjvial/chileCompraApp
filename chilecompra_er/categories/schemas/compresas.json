        "gel",
        "gasa",
        "cotonoide",
        "hemostatica",
        "calentador",
        "contador",
        "cubrecompresa"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bcubrecompresa",
          "value": "cubrecompresa"
        },
        {
          "kind": "keyword",
          "pattern": "\\bcalentador",
          "value": "calentador"
        },
        {
          "kind": "keyword",
