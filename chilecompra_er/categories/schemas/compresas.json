        {
          "kind": "keyword",
          "pattern": "surgicel|gelita|hemostatic",
          "value": "hemostatica"
        },
        {
          "kind": "keyword",
          "pattern": "frio\\s*calor|frio\\s*y\\s*calor|cold\\s*hot",
          "value": "frio_calor"
        },
        {
          "kind": "keyword",
          "pattern": "humed\\w*\\s+cali",
          "value": "humedo_caliente"
        },
        {
          "kind": "keyword",
          "pattern": "\\bfri[ao]s?\\b",
          "value": "fria"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgel\\b",
          "value": "gel"
        },
        {
          "kind": "keyword",
          "pattern": "\\bgasa|\\bgenero|\\bcrea\\b|optilon|maternidad|radiop",
          "value": "gasa"
        }
      ],
      "curation_notes": "Identidad funcional/material que separa familias distintas (paquete humedo caliente, fria, gel, gasa textil, cotonoide neuroquirurgico, hemostatica, y accesorios como calentador/contador/cubrecompresa); reglas de mas especifica a mas general."
