{
  "category_id": "suplementos_nutricionales",
  "name": "Suplementos nutricionales",
  "schema_version": "0.1.0-draft",
  "status": "draft",
  "base_unit": "unidad (1 envase de suplemento)",
  "curation_log": [
    "DRAFT generated by the LLM strawman (design §3 step 5) from real corpus samples — cheap and disposable, never authoritative. Requires the full M1 procedure (mining passes, price-discrimination test, expert curation, reference validation) before launch.",
    "Dry run on 50 corpus samples: coverage {'tipo_producto': 0.36, 'forma': 0.5, 'indicacion': 0.32, 'densidad_calorica': 0.22, 'sabor': 0.16}, illegal extractions 0."
  ],
  "attribute_defs": [
    {
      "name": "tipo_producto",
      "role": "identity",
      "domain": [
        "formula_completa",
        "modulo_proteico",
        "modulo_calorico",
        "espesante",
        "multivitaminico",
        "formula_infantil"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bespesante\\b",
          "value": "espesante"
        },
        {
          "kind": "keyword",
          "pattern": "modulo\\s+(?:de\\s+)?prote(?:ico|ina)|100\\s*%\\s*prote(?:ina|inas)\\s+de\\s+suero",
          "value": "modulo_proteico"
        },
        {
          "kind": "keyword",
          "pattern": "modulo\\s+calorico|almidon\\s+de\\s+maiz|nat\\s*100",
          "value": "modulo_calorico"
        },
        {
          "kind": "keyword",
          "pattern": "multivitaminico",
          "value": "multivitaminico"
        },
        {
          "kind": "keyword",
          "pattern": "lactante|lactia|0\\s+a\\s+6\\s+meses|formula\\s+lactea\\s+infantil",
          "value": "formula_infantil"
        },
        {
          "kind": "keyword",
          "pattern": "formula\\s+(?:completa|polimerica|nutricional\\s+completa)|nutricionalmente\\s+completa|completa\\s+y\\s+balanceada",
          "value": "formula_completa"
        }
      ],
      "curation_notes": "Identity: distingue el tipo funcional del producto (formula completa vs modulo aislado vs espesante vs multivitaminico vs formula infantil); dominio cerrado observado en las descripciones."
    },
    {
      "name": "forma",
      "role": "identity",
      "domain": [
        "liquido",
        "polvo",
        "semisolido"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "semi\\s*solido|consistencia\\s+modificada|tipo\\s+crema",
          "value": "semisolido"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpolvo\\b|\\bsachet\\b",
          "value": "polvo"
        },
        {
          "kind": "keyword",
          "pattern": "\\bliquido\\b|\\bml\\b|\\bcc\\b|cal\\s*ml|kcal\\s*ml",
          "value": "liquido"
        }
      ],
      "curation_notes": "Identity: la forma fisica (liquido listo, polvo a reconstituir, semisolido) discrimina presentaciones distintas; el polvo explicito gana sobre la senal liquida de ml/cc."
    },
    {
      "name": "indicacion",
      "role": "identity",
      "domain": [
        "estandar",
        "diabetico",
        "renal",
        "inmunonutricion"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\brenal\\b|pre\\s*dialisis|falla\\s+renal|restriccion\\s+hidrica|nepro",
          "value": "renal"
        },
        {
          "kind": "keyword",
          "pattern": "diabet|glucerna|libre\\s+de\\s+sacarosa|intolerancia\\s+a\\s+la\\s+glucosa|tolerancia\\s+anormal\\s+a\\s+la\\s+glucosa",
          "value": "diabetico"
        },
        {
          "kind": "keyword",
          "pattern": "glutamina|arginina|estres\\s+oxidativo|glutapak",
          "value": "inmunonutricion"
        },
        {
          "kind": "keyword",
          "pattern": "estandar|completa\\s+y\\s+balanceada|polimerica",
          "value": "estandar"
        }
      ],
      "curation_notes": "Identity: la indicacion clinica especializada (renal, diabetico, inmunonutricion) define un producto distinto del estandar; estandar como valor por defecto cuando hay senal de formula generica."
    },
    {
      "name": "densidad_calorica",
      "role": "identity",
      "domain": [
        "1_0kcal_ml",
        "1_5kcal_ml",
        "2_0kcal_ml"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\b2(?:\\.0)?\\s*(?:kcal|cal|kcl)\\b",
          "value": "2_0kcal_ml"
        },
        {
          "kind": "keyword",
          "pattern": "\\b1\\.5\\s*(?:kcal|cal|kcl)\\b",
          "value": "1_5kcal_ml"
        },
        {
          "kind": "keyword",
          "pattern": "\\b1(?:\\.0[0-9]?)?\\s*(?:kcal|cal|kcl)\\b",
          "value": "1_0kcal_ml"
        }
      ],
      "curation_notes": "Identity: la densidad calorica (1.0 isotonica/estandar, 1.5 hipercalorica, 2.0 alta densidad) diferencia formulas liquidas; valores discretos canonicos a las bandas observadas, 1.05 se mapea a 1_0.",
      "unit": "kcal/ml"
    },
    {
      "name": "sabor",
      "role": "descriptive",
      "domain": [
        "vainilla",
        "frutilla",
        "chocolate",
        "mora",
        "salado",
        "natural"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "vainilla",
          "value": "vainilla"
        },
        {
          "kind": "keyword",
          "pattern": "frutilla",
          "value": "frutilla"
        },
        {
          "kind": "keyword",
          "pattern": "chocolate",
          "value": "chocolate"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmora\\b",
          "value": "mora"
        },
        {
          "kind": "keyword",
          "pattern": "\\bsalado\\b",
          "value": "salado"
        }
      ],
      "curation_notes": "Descriptive: el mismo producto suele ofrecerse en varios sabores (a menudo 'sabor previa coordinacion'), por lo que se normaliza pero no participa en la igualdad."
    }
  ]
}