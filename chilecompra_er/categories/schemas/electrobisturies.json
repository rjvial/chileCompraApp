        },
        {
          "kind": "keyword",
          "pattern": "\\blimpiador\\b",
          "value": "limpiador"
        },
        {
          "kind": "keyword",
          "pattern": "\\blija\\b",
          "value": "lija"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpinzas?\\b",
          "value": "pinza"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmangos?\\b",
          "value": "mango"
        },
        {
          "kind": "keyword",
          "pattern": "\\baguja\\b",
          "value": "aguja"
        },
        {
          "kind": "keyword",
          "pattern": "\\badaptador\\b",
