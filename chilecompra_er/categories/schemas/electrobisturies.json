        {
          "kind": "keyword",
          "pattern": "\\blapiz\\b",
          "value": "lapiz"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(electrobisturi|electrobisturies|electroquirurgica)\\b",
          "value": "equipo"
        }
      ],
      "curation_notes": "Identity: distingue el objeto real (equipo, accesorio o servicio) que comparten la palabra electrobisturi; reglas de mas especifico (servicio, accesorios concretos) a general (equipo como fallback)."
    },
    {
      "name": "modalidad",
      "role": "identity",
      "domain": [
        "monopolar",
        "bipolar"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bbipolar(es)?\\b",
          "value": "bipolar"
        },
        {
          "kind": "keyword",
          "pattern": "\\bmo[mn]opolar\\b",
          "value": "monopolar"
        }
      ],
      "curation_notes": "Identity: bipolar vs monopolar define accesorios y cables electricamente incompatibles; incluye typo momopolar observado."
    },
    {
      "name": "segmento_paciente",
      "role": "identity",
      "domain": [
        "adulto",
        "pediatrico",
        "neonatal"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bneonatal\\b",
          "value": "neonatal"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(p\\s+)?rn\\b",
          "value": "neonatal"
        },
        {
          "kind": "keyword",
          "pattern": "\\b(pediatric[ao]|infantil)\\b",
          "value": "pediatrico"
        },
        {
          "kind": "keyword",
          "pattern": "\\badulto\\b",
          "value": "adulto"
        },
        {
          "kind": "keyword",
          "pattern": "\\bpediatrica\\b",
          "value": "pediatrico"
        }
      ],
      "curation_notes": "Identity: las placas se fabrican por tamano de paciente (adulto/pediatrico/neonatal) y no son intercambiables; rn y recien nacido mapean a neonatal."
    },
    {
      "name": "condicion_uso",
      "role": "identity",
      "domain": [
        "desechable",
        "reutilizable"
      ],
      "rules": [
        {
          "kind": "keyword",
          "pattern": "\\bdesechable\\b",
          "value": "desechable"
        },
        {
          "kind": "keyword",
          "pattern": "\\breutilizable",
          "value": "reutilizable"
        }
      ],
      "curation_notes": "Identity: desechable vs reutilizable distingue productos con uso, costeo y limpieza distintos; pattern sin limite final captura reutilizablenon sin espacio."
    },
    {
      "name": "esteril",
      "role": "descriptive",
      "domain": [
